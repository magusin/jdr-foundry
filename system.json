{
  "id": "rpg",
  "title": "RPG",
  "description": "Système maison (MMO-tabletop)",
  "version": "0.3.0",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "template": "template.json",
  "templateVersion": 2,
  "authors": [
    {
      "name": "Hugo"
    }
  ],
  "esmodules": [
    "module/init.js"
  ],
  "styles": [
    "styles/character-sheet.css",
    "styles/menu-macro.css",
    "styles/spell-sheet.css",
    "styles/armor-sheet.css",
    "styles/item-sheet.css",
    "styles/weapon-sheet.css"
  ],
  "languages": [
    {
      "lang": "fr",
      "name": "Français",
      "path": "lang/fr.json"
    }
  ],
  "packs": [
    {
      "name": "macros-rpg",
      "label": "Macros système",
      "path": "packs/macros/macros.db",
      "type": "Macro"
    },
    {
      "name": "items-reference",
      "label": "Équipement de référence",
      "path": "packs/items/items.db",
      "type": "Item"
    },
    {
      "name": "loot-tables",
      "label": "Tables de Butin",
      "path": "packs/loot-tables/loot-tables.db",
      "type": "RollTable"
    },
    {
      "name": "monsters-reference",
      "label": "Monstres de Référence",
      "path": "packs/monsters/monsters.db",
      "type": "Actor"
    },
    {
      "name": "documentation",
      "label": "Documentation",
      "path": "packs/documentation/documentation.db",
      "type": "JournalEntry"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {},
      "monster": {}
    },
    "Item": {
      "loot": {},
      "weapon": {},
      "armor": {},
      "consumable": {},
      "spell": {},
      "recipe": {},
      "quest": {}
    },
    "RegionBehavior": {
      "terrainDifficile": {},
      "vegetationDense": {},
      "eauPeuProfonde": {},
      "eauProfonde": {},
      "boue": {},
      "courant": {}
    }
  },
  "grid": {
    "type": 1,
    "size": 100,
    "distance": 1,
    "units": "m",
    "style": "solidLines",
    "thickness": 1,
    "color": "#000000",
    "alpha": 0.2
  }
}