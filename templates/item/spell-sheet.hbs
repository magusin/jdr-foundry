<form class="rpg-sheet rpg-spell-sheet" autocomplete="off">
  <header class="sheet-header">
    <div style="display:flex;align-items:center;gap:10px">
      <img class="rpg-img-edit" src="{{item.img}}" data-field="img" title="Changer l'image"
        style="width:48px;height:48px;cursor:{{#if canEdit}}pointer{{else}}default{{/if}};border-radius:8px;border:1px solid var(--color-border-light-2)"/>
      {{#if canEdit}}
      <input name="name" type="text" value="{{item.name}}" placeholder="Nom du sort" style="flex:1;font-size:1.3em;font-weight:700"/>
      {{else}}
      <h2 style="flex:1;margin:0">{{item.name}}</h2>
      {{/if}}
      {{#if isGM}}<span style="font-size:10px;padding:2px 8px;border-radius:10px;background:rgba(180,120,0,0.2);color:#c8960a">MJ</span>{{/if}}
    </div>
  </header>

  <section class="sheet-body" style="display:flex;flex-direction:column;gap:10px;padding:10px">

    {{!-- ═══ INFOS GÉNÉRALES ═══ --}}
    <section class="card">
      <h2>Général</h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px">

        <div>
          <label>Vitesse</label>
          {{#if canEdit}}
          <select name="system.speed" style="width:100%">
            <option value="passif" {{#if (eq system.speed "passif")}}selected{{/if}}>Passif</option>
            <option value="rapide" {{#if (eq system.speed "rapide")}}selected{{/if}}>Rapide</option>
            <option value="normal" {{#if (eq system.speed "normal")}}selected{{/if}}>Normal</option>
          </select>
          {{else}}<div><b>{{system.speed}}</b></div>{{/if}}
        </div>

        <div>
          <label>Livraison</label>
          {{#if canEdit}}
          <select name="system.livraison" style="width:100%">
            <option value="magique"  {{#if (eq system.livraison "magique")}}selected{{/if}}>Magique</option>
            <option value="physique" {{#if (eq system.livraison "physique")}}selected{{/if}}>Physique</option>
          </select>
          {{else}}<div><b>{{system.livraison}}</b></div>{{/if}}
        </div>

        <div>
          <label>Élément / Type</label>
          {{#if canEdit}}
          <select name="system.tag" style="width:100%">
            <option value="neutre"    {{#if (eq system.tag "neutre")}}selected{{/if}}>⚪ Neutre</option>
            <option value="feu"       {{#if (eq system.tag "feu")}}selected{{/if}}>🔥 Feu</option>
            <option value="eau"       {{#if (eq system.tag "eau")}}selected{{/if}}>💧 Eau</option>
            <option value="eclair"    {{#if (eq system.tag "eclair")}}selected{{/if}}>⚡ Éclair</option>
            <option value="glace"     {{#if (eq system.tag "glace")}}selected{{/if}}>❄️ Glace</option>
            <option value="air"       {{#if (eq system.tag "air")}}selected{{/if}}>💨 Air</option>
            <option value="terre"     {{#if (eq system.tag "terre")}}selected{{/if}}>🌍 Terre</option>
            <option value="lumiere"   {{#if (eq system.tag "lumiere")}}selected{{/if}}>✨ Lumière</option>
            <option value="obscurite" {{#if (eq system.tag "obscurite")}}selected{{/if}}>🌑 Obscurité</option>
          </select>
          {{else}}
          <div style="font-size:13px">
            {{#if (eq system.tag "feu")}}🔥 Feu{{/if}}
            {{#if (eq system.tag "eau")}}💧 Eau{{/if}}
            {{#if (eq system.tag "eclair")}}⚡ Éclair{{/if}}
            {{#if (eq system.tag "glace")}}❄️ Glace{{/if}}
            {{#if (eq system.tag "air")}}💨 Air{{/if}}
            {{#if (eq system.tag "terre")}}🌍 Terre{{/if}}
            {{#if (eq system.tag "lumiere")}}✨ Lumière{{/if}}
            {{#if (eq system.tag "obscurite")}}🌑 Obscurité{{/if}}
            {{#if (eq system.tag "neutre")}}⚪ Neutre{{/if}}
            {{#unless system.tag}}⚪ Neutre{{/unless}}
          </div>
          {{/if}}
        </div>

        <div>
          <label>Coût Mana</label>
          {{#if canEdit}}<input type="number" name="system.coutMana" value="{{system.coutMana}}" min="0" style="width:100%"/>
          {{else}}<div><b>{{system.coutMana}}</b></div>{{/if}}
          {{#if weatherEffect}}
          <div style="margin-top:3px;padding:3px 6px;border-radius:4px;font-size:11px;font-weight:600;
            background:{{weatherEffect.color}}22;border:1px solid {{weatherEffect.color}}44;color:{{weatherEffect.color}}">
            {{weatherEffect.icon}} {{weatherEffect.label}} : {{weatherEffect.manaCoutEffectif}} mana
            ({{weatherEffect.mult}})
          </div>
          {{/if}}
        </div>

        <div>
          <label>Portée min</label>
          {{#if canEdit}}<input type="number" name="system.range.min" value="{{system.range.min}}" min="0" step="0.1" style="width:100%"/>
          {{else}}<div><b>{{system.range.min}}</b></div>{{/if}}
        </div>

        <div>
          <label>Portée max</label>
          {{#if canEdit}}<input type="number" name="system.range.max" value="{{system.range.max}}" min="0" step="0.1" style="width:100%"/>
          {{else}}<div><b>{{system.range.max}}</b></div>{{/if}}
        </div>

        <div>
          <label>Difficulté (TN+)</label>
          {{#if canEdit}}<input type="number" name="system.difficulte" value="{{system.difficulte}}" min="0" style="width:100%"/>
          {{else}}<div><b>{{system.difficulte}}</b></div>{{/if}}
        </div>

        <div>
          <label>Cibles min</label>
          {{#if canEdit}}<input type="number" name="system.targetCount.min" value="{{system.targetCount.min}}" min="0" style="width:100%"/>
          {{else}}<div><b>{{system.targetCount.min}}</b></div>{{/if}}
        </div>

        <div>
          <label>Cibles max</label>
          {{#if canEdit}}<input type="number" name="system.targetCount.max" value="{{system.targetCount.max}}" min="0" style="width:100%"/>
          {{else}}<div><b>{{system.targetCount.max}}</b></div>{{/if}}
        </div>

        <div>
          <label>Coût fatigue</label>
          {{#if canEdit}}<input type="number" name="system.fatigueCost" value="{{system.fatigueCost}}" min="0" style="width:100%"/>
          {{else}}<div><b>{{system.fatigueCost}}</b></div>{{/if}}
        </div>

        <div>
          <label>Recharge max</label>
          {{#if canEdit}}<input type="number" name="system.cooldown.max" value="{{system.cooldown.max}}" min="0" style="width:100%"/>
          {{else}}<div><b>{{system.cooldown.max}}</b></div>{{/if}}
        </div>

        <div>
          <label>Recharge restante</label>
          <input type="number" name="system.cooldown.restant" value="{{system.cooldown.restant}}" min="0" style="width:100%"/>
        </div>

      </div>
    </section>

    {{!-- ═══ DÉGÂTS (multiples lignes) ═══ --}}
    <section class="card">
      <div style="display:flex;align-items:center;justify-content:space-between">
        <h2>Dégâts</h2>
        {{#if canEdit}}
        <button type="button" data-action="addDmgLine" style="padding:2px 10px;cursor:pointer">+ Ligne</button>
        {{/if}}
      </div>

      {{#if system.damages.length}}
      <div style="display:grid;grid-template-columns:75px 50px 110px 50px 60px 75px 90px 28px;gap:4px;padding:0 4px 2px;font-size:10px;opacity:.65;font-weight:600">
        <span>Dés</span><span>Plat</span><span>Stat</span><span>Par</span><span>Gain/niv</span><span>Crit dés</span><span>Livraison</span><span></span>
      </div>
      {{/if}}

      {{#each system.damages as |dmg i|}}
      <div class="dmg-row" data-idx="{{i}}"
        style="display:grid;grid-template-columns:75px 50px 110px 50px 60px 75px 90px 28px;gap:4px;align-items:center;margin-bottom:4px;padding:4px 4px;background:var(--surface);border-radius:6px">
        <input type="text"   name="system.damages.{{i}}.dice"     value="{{dmg.dice}}"     placeholder="1d6" style="font-size:12px"/>
        <input type="number" name="system.damages.{{i}}.flat"     value="{{dmg.flat}}"     placeholder="0"   style="font-size:12px"/>
        <select              name="system.damages.{{i}}.stat"                                                 style="font-size:12px">
          <option value="intelligence" {{#if (eq dmg.stat "intelligence")}}selected{{/if}}>Intelligence</option>
          <option value="force"        {{#if (eq dmg.stat "force")}}selected{{/if}}>Force</option>
          <option value="dexterite"    {{#if (eq dmg.stat "dexterite")}}selected{{/if}}>Dextérité</option>
          <option value="acuite"       {{#if (eq dmg.stat "acuite")}}selected{{/if}}>Acuité</option>
          <option value="endurance"    {{#if (eq dmg.stat "endurance")}}selected{{/if}}>Endurance</option>
          <option value=""             {{#unless dmg.stat}}selected{{/unless}}>— aucune</option>
        </select>
        <input type="number" name="system.damages.{{i}}.per"      value="{{dmg.per}}"      placeholder="10"  style="font-size:12px"/>
        <input type="number" name="system.damages.{{i}}.perStep"  value="{{dmg.perStep}}"  placeholder="1"   style="font-size:12px"/>
        <input type="text"   name="system.damages.{{i}}.critDice" value="{{dmg.critDice}}" placeholder="1d6" style="font-size:12px"/>
        <select              name="system.damages.{{i}}.livraison"                                            style="font-size:12px">
          <option value="magique"  {{#if (eq dmg.livraison "magique")}}selected{{/if}}>Magique</option>
          <option value="physique" {{#if (eq dmg.livraison "physique")}}selected{{/if}}>Physique</option>
        </select>
        {{#if canEdit}}
        <button type="button" data-action="removeDmgLine" data-idx="{{i}}"
          style="cursor:pointer;color:#c0392b;border:none;background:none;font-size:14px;padding:0">✕</button>
        {{else}}<span></span>{{/if}}
      </div>
      {{/each}}

      {{#unless system.damages.length}}
      <div style="font-size:11px;opacity:.6;padding:4px">Aucune ligne — clique "+ Ligne" pour en ajouter.</div>
      {{/unless}}
    </section>

    {{!-- ═══ EFFETS ═══ --}}
    <section class="card">
      <div style="display:flex;align-items:center;justify-content:space-between">
        <h2>Effets secondaires</h2>
        {{#if canEdit}}
        <button type="button" data-action="addEffect" style="padding:2px 10px;cursor:pointer">+ Effet</button>
        {{/if}}
      </div>

      {{#each system.effectsUI as |fx i|}}
      <details class="fx-card" data-fx-index="{{i}}"
        style="border:1px solid var(--color-border-light-2);border-radius:10px;margin-bottom:6px;overflow:hidden">
        <summary style="cursor:pointer;padding:8px 12px;background:var(--surface);display:flex;align-items:center;gap:8px;list-style:none">
          <span style="flex:1;font-weight:600">{{#if fx.label}}{{fx.label}}{{else}}Effet {{i}}{{/if}}</span>
          {{#if fx.tag}}<span style="font-size:11px;padding:1px 6px;border-radius:4px;background:var(--surface-2)">{{fx.tag}}</span>{{/if}}
          {{#if fx.dot.perTick}}<span style="font-size:11px;opacity:.7">{{fx.dot.perTick}} dég/tour</span>{{/if}}
          {{#if canEdit}}
          <button type="button" data-action="removeEffect" data-fx-index="{{i}}"
            style="cursor:pointer;background:none;border:none;color:#c0392b;font-size:14px;padding:0 4px">✕</button>
          {{/if}}
        </summary>

        <div style="padding:10px 12px;display:flex;flex-direction:column;gap:8px">

          {{!-- Sélecteur catalogue + nom --}}
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
            <div>
              <label style="font-size:11px">Effet du catalogue (auto-remplit nom + type)</label>
              {{#if canEdit}}
              <select class="fx-catalogue-select" data-fx-idx="{{i}}" style="width:100%">
                <option value="">— Nom libre —</option>
                {{#each @root.EFFECT_CATALOG as |group gLabel|}}
                <optgroup label="{{gLabel}}">
                  {{#each group as |e|}}
                  <option value="{{e.key}}" data-tag="{{e.tag}}" data-label="{{e.label}}"
                    {{#if (eq fx.effectKey e.key)}}selected{{/if}}>{{e.label}}</option>
                  {{/each}}
                </optgroup>
                {{/each}}
              </select>
              {{/if}}
            </div>
            <div>
              <label style="font-size:11px">Nom affiché</label>
              {{#if canEdit}}
              <input type="text" name="system.effectsUI.{{i}}.label" value="{{fx.label}}"
                placeholder="Nom de l'effet" style="width:100%"/>
              {{else}}<div><b>{{fx.label}}</b></div>{{/if}}
            </div>
          </div>

          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px">
            <div>
              <label style="font-size:11px">Type / Élément</label>
              {{#if canEdit}}
              <select name="system.effectsUI.{{i}}.tag" style="width:100%">
                <option value="" {{#unless fx.tag}}selected{{/unless}}>— Aucun —</option>
                <option value="magique"  {{#if (eq fx.tag "magique")}}selected{{/if}}>✨ Magique</option>
                <option value="physique" {{#if (eq fx.tag "physique")}}selected{{/if}}>⚔️ Physique</option>
                <option value="feu"    {{#if (eq fx.tag "feu")}}selected{{/if}}>🔥 Feu</option>
                <option value="air"    {{#if (eq fx.tag "air")}}selected{{/if}}>🌬️ Air</option>
                <option value="eau"    {{#if (eq fx.tag "eau")}}selected{{/if}}>💧 Eau</option>
                <option value="glace"  {{#if (eq fx.tag "glace")}}selected{{/if}}>❄️ Glace</option>
                <option value="eclair" {{#if (eq fx.tag "eclair")}}selected{{/if}}>⚡ Éclair</option>
                <option value="terre"  {{#if (eq fx.tag "terre")}}selected{{/if}}>🌿 Terre</option>
              </select>
              {{else}}<div><b>{{fx.tag}}</b></div>{{/if}}
            </div>
            <div>
              <label style="font-size:11px">Durée (tours)</label>
              {{#if canEdit}}<input type="number" name="system.effectsUI.{{i}}.duration" value="{{fx.duration}}" min="0" style="width:100%"/>
              {{else}}<div><b>{{fx.duration}}</b></div>{{/if}}
            </div>
            <div>
              <label style="font-size:11px">TN retrait <span style="opacity:.6">(0=impossible)</span></label>
              {{#if canEdit}}<input type="number" name="system.effectsUI.{{i}}.removeBaseTN" value="{{fx.removeBaseTN}}" min="0" max="20" placeholder="0" style="width:100%"/>
              {{else}}<div>{{#if fx.removeBaseTN}}<b>{{fx.removeBaseTN}}+</b>{{else}}—{{/if}}</div>{{/if}}
            </div>
            <div>
              <label style="font-size:11px">Mod retrait <span style="opacity:.6">(+/- au TN)</span></label>
              {{#if canEdit}}<input type="number" name="system.effectsUI.{{i}}.retraitMod" value="{{fx.retraitMod}}" placeholder="0" style="width:100%"/>
              {{else}}<div>{{#if fx.retraitMod}}<span style="color:{{#if (gt fx.retraitMod 0)}}#c0392b{{else}}#1d9e75{{/if}}">{{#if (gt fx.retraitMod 0)}}+{{/if}}{{fx.retraitMod}}</span>{{else}}—{{/if}}</div>{{/if}}
            </div>
            <div>
              <label style="font-size:11px">🏃 Mode déplacement accordé</label>
              {{#if canEdit}}
              <select name="system.effectsUI.{{i}}.movementTypeGrant" style="width:100%">
                <option value="" {{#unless fx.movementTypeGrant}}selected{{/unless}}>— Aucun —</option>
                <option value="volant"     {{#if (eq fx.movementTypeGrant "volant")}}selected{{/if}}>🦅 Vol</option>
                <option value="aquatique"  {{#if (eq fx.movementTypeGrant "aquatique")}}selected{{/if}}>🐟 Nage</option>
                <option value="amphibie"   {{#if (eq fx.movementTypeGrant "amphibie")}}selected{{/if}}>🐸 Amphibie</option>
                <option value="ethere"     {{#if (eq fx.movementTypeGrant "ethere")}}selected{{/if}}>👻 Éthéré</option>
                <option value="montagnard" {{#if (eq fx.movementTypeGrant "montagnard")}}selected{{/if}}>⛰️ Montagnard</option>
                <option value="forestier"  {{#if (eq fx.movementTypeGrant "forestier")}}selected{{/if}}>🌲 Forestier</option>
              </select>
              {{else}}
              <div style="font-size:12px">{{#if fx.movementTypeGrant}}{{fx.movementTypeGrant}}{{else}}—{{/if}}</div>
              {{/if}}
            </div>
            <div>
              <label style="font-size:11px">Dégâts/tour <span style="opacity:.6">(négatif=soin)</span></label>
              {{#if canEdit}}<input type="number" name="system.effectsUI.{{i}}.damage.flat" value="{{fx.damage.flat}}" placeholder="0" style="width:100%"/>
              {{else}}<div>{{fx.damage.flat}}</div>{{/if}}
            </div>
            <div>
              <label style="font-size:11px">Fatigue/tour <span style="opacity:.6">(négatif=repos)</span></label>
              {{#if canEdit}}<input type="number" name="system.effectsUI.{{i}}.fatigueDot" value="{{fx.fatigueDot}}" placeholder="0" style="width:100%"/>
              {{else}}<div>{{fx.fatigueDot}}</div>{{/if}}
            </div>
          </div>

          <div style="display:flex;gap:12px">
            <label style="font-size:11px;display:flex;align-items:center;gap:4px">
              <input type="checkbox" name="system.effectsUI.{{i}}.permanent" {{#if fx.permanent}}checked{{/if}} />
              Permanent
            </label>
            <label style="font-size:11px;display:flex;align-items:center;gap:4px">
              <input type="checkbox" name="system.effectsUI.{{i}}.isAura" {{#if fx.isAura}}checked{{/if}} />
              Aura
            </label>
            {{#if fx.isAura}}
            <span style="font-size:11px;display:flex;align-items:center;gap:4px">
              Portée :
              <input type="number" name="system.effectsUI.{{i}}.auraMin" value="{{fx.auraMin}}" min="0" step="0.1" style="width:45px" />
              –
              <input type="number" name="system.effectsUI.{{i}}.auraMax" value="{{fx.auraMax}}" min="0" step="0.1" style="width:45px" />
            </span>
            {{/if}}
          </div>

          {{!-- Modificateurs de stat --}}
          {{#if canEdit}}
          <div>
            <div style="font-size:11px;font-weight:600;margin-bottom:4px">Modificateurs de stat
              <span style="font-weight:400;opacity:.7">— Fixe / %</span>
              <button type="button" data-action="addMod" data-fx-idx="{{i}}"
                style="font-size:11px;cursor:pointer;margin-left:6px">+ Stat</button>
            </div>
            <div class="fx-mods-list" data-fx-idx="{{i}}">
              {{#each fx.mods as |mod mKey|}}
              <div class="fx-mod-row" style="display:flex;gap:4px;align-items:center;margin-bottom:3px">
                <span style="font-size:11px;flex:1">{{mKey}}</span>
                <input type="number" name="system.effectsUI.{{i}}.mods.{{mKey}}.flat" value="{{mod.flat}}"
                  placeholder="Fixe" style="width:60px"/>
                <input type="number" name="system.effectsUI.{{i}}.mods.{{mKey}}.pct" value="{{mod.pct}}"
                  placeholder="%" style="width:55px"/>
                <button type="button" data-action="removeMod" data-fx-idx="{{i}}" data-mod-key="{{mKey}}"
                  style="cursor:pointer;color:#c0392b;border:none;background:none">✕</button>
              </div>
              {{/each}}
            </div>
          </div>
          {{else}}
          {{#if fx.mods}}
          <div style="font-size:11px;opacity:.7">
            {{#each fx.mods as |mod mKey|}}
            <span>{{mKey}} : {{#if mod.flat}}{{mod.flat}}{{/if}}{{#if mod.pct}} / {{mod.pct}}%{{/if}} </span>
            {{/each}}
          </div>
          {{/if}}
          {{/if}}

        </div>
      </details>
      {{/each}}
    </section>

    {{!-- ═══ DESCRIPTION ═══ --}}
    <section class="card">
      <h2>Description</h2>
      {{#if canEdit}}
      <textarea name="system.description" rows="4" style="width:100%">{{system.description}}</textarea>
      {{else}}
      <div style="white-space:pre-wrap">{{system.description}}</div>
      {{/if}}
    </section>

  </section>
</form>
