<form class="rpg-sheet rpg-quest-sheet">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields">
      <input name="name" type="text" value="{{item.name}}" placeholder="Nom de la quête" {{#unless canEdit}}disabled{{/unless}} />
    </div>
  </header>

  <section class="sheet-body">

    <div class="form-group">
      <label>Statut global</label>
      <select name="system.statut" {{#unless canEdit}}disabled{{/unless}}>
        <option value="active" {{#if (eq system.statut "active")}}selected{{/if}}>En cours</option>
        <option value="reussie" {{#if (eq system.statut "reussie")}}selected{{/if}}>Réussie</option>
        <option value="echouee" {{#if (eq system.statut "echouee")}}selected{{/if}}>Échouée</option>
      </select>
    </div>

    <div class="form-group">
      <label>
        <input type="checkbox" name="system.partagee" {{#if system.partagee}}checked{{/if}} {{#unless canEdit}}disabled{{/unless}} />
        Quête partagée (plusieurs PJ peuvent l'avoir, la progression reste synchronisée pour tous)
      </label>
    </div>

    <div class="form-group">
      <label>Classe / Joueur requis (note pour toi, n'apparaît jamais au joueur)</label>
      <input type="text" name="system.classeRequise" value="{{system.classeRequise}}"
        placeholder="ex: Mage uniquement, ou nom du joueur" {{#unless canEdit}}disabled{{/unless}} />
    </div>

    <div class="form-group">
      <label>Étape actuelle (le joueur ne voit que celle-ci + les étapes terminées en titre seul)</label>
      <div style="font-size:13px;font-weight:600">
        Étape {{calc.etapeActuelleNum}} / {{calc.totalEtapes}}
      </div>
    </div>

    <h3>Déroulé de la quête (étapes)</h3>
    <div class="quest-etapes">
      {{#each system.etapes as |etape ei|}}
      <div class="etape-card" data-etape-idx="{{ei}}"
           style="border:1px solid var(--color-border-tertiary);border-radius:8px;padding:8px;margin-bottom:8px;
                  {{#if (eq ei ../system.etapeActuelle)}}background:rgba(29,158,117,0.08);{{/if}}">

        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
          <span style="font-size:11px;font-weight:700;opacity:.7">
            Étape {{etape.etapeNum}}
            {{#if (eq ei ../system.etapeActuelle)}}<span style="color:#1d9e75">— EN COURS</span>{{/if}}
            {{#if (lt ei ../system.etapeActuelle)}}<span style="color:var(--color-text-secondary)">— terminée</span>{{/if}}
            {{#if (gt ei ../system.etapeActuelle)}}<span style="color:var(--color-text-secondary)">— à venir (caché du joueur)</span>{{/if}}
          </span>
          {{#if canEdit}}
          <button type="button" data-action="removeEtape" data-etape-idx="{{ei}}" style="margin-left:auto" title="Retirer l'étape">✕</button>
          {{/if}}
        </div>

        <input type="text" name="system.etapes.{{ei}}.label" value="{{etape.label}}"
          placeholder="Titre de l'étape (ex: Trouver l'auberge)" style="width:100%;margin-bottom:6px"
          {{#unless ../canEdit}}disabled{{/unless}} />

        <div class="etape-objectifs">
          {{#each etape.objectifs as |obj oi|}}
          <div style="display:flex;gap:6px;align-items:center;margin-bottom:3px">
            <input type="checkbox" name="system.etapes.{{ei}}.objectifs.{{oi}}.fait" {{#if obj.fait}}checked{{/if}}
              {{#unless ../../canEdit}}disabled{{/unless}} />
            <input type="text" name="system.etapes.{{ei}}.objectifs.{{oi}}.text" value="{{obj.text}}"
              placeholder="Description de l'objectif" style="flex:1" {{#unless ../../canEdit}}disabled{{/unless}} />
            {{#if ../../canEdit}}
            <button type="button" data-action="removeObjectif" data-etape-idx="{{ei}}" data-obj-idx="{{oi}}" title="Retirer">✕</button>
            {{/if}}
          </div>
          {{/each}}
        </div>
        {{#if canEdit}}
        <button type="button" data-action="addObjectif" data-etape-idx="{{ei}}" style="margin-top:2px;font-size:11px">+ Objectif</button>
        {{/if}}
      </div>
      {{/each}}
    </div>

    {{#if canEdit}}
    <div style="display:flex;gap:8px;margin-top:6px">
      <button type="button" data-action="addEtape">+ Ajouter une étape</button>
      <button type="button" data-action="prevEtape">◀ Étape précédente</button>
      <button type="button" data-action="nextEtape">Étape suivante ▶</button>
    </div>
    {{/if}}

    <h3 style="margin-top:14px">Récompense (à la fin de la quête)</h3>
    <div class="form-group">
      <label>XP</label>
      <input type="number" name="system.recompense.xp" value="{{system.recompense.xp}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
    </div>

    <div class="quest-reward-items">
      {{#each system.recompense.items as |ri idx|}}
      <div class="reward-row" data-idx="{{idx}}" style="display:flex;gap:6px;align-items:center;margin-bottom:4px">
        <input type="text" name="system.recompense.items.{{idx}}.uuid" value="{{ri.uuid}}"
          placeholder="UUID de l'objet (clic droit -> Copy UUID)" style="flex:2" {{#unless canEdit}}disabled{{/unless}} />
        <input type="text" name="system.recompense.items.{{idx}}.name" value="{{ri.name}}"
          placeholder="Nom affiché" style="flex:1" {{#unless canEdit}}disabled{{/unless}} />
        <input type="number" name="system.recompense.items.{{idx}}.qty" value="{{ri.qty}}" min="1" style="width:50px" {{#unless canEdit}}disabled{{/unless}} />
        {{#if canEdit}}
        <button type="button" data-action="removeRewardItem" data-idx="{{idx}}" title="Retirer">✕</button>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{#if canEdit}}
    <button type="button" data-action="addRewardItem" style="margin-top:4px">+ Ajouter un objet en récompense</button>
    {{/if}}

    <h3 style="margin-top:14px">Description</h3>
    <textarea name="system.description" rows="5" {{#unless canEdit}}disabled{{/unless}}>{{system.description}}</textarea>

  </section>
</form>
