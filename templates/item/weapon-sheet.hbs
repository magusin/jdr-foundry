{{!-- systems/rpg/templates/item/item-weapon-sheet.hbs --}}
<div class="rpg-sheet weapon-sheet" autocomplete="off">

  <header class="sheet-header weapon-header">
    <img class="profile" src="{{item.img}}" {{#if canEdit}}data-edit="img"{{/if}} title="{{item.name}}" height="64" width="64"/>
    <div class="title-block">
      {{#if isReadOnly}}
        <div class="name-readonly"><b>{{item.name}}</b></div>
      {{else}}
        <input class="name-input" name="name" type="text" value="{{item.name}}"/>
      {{/if}}
      <small>{{item.type}}</small>
    </div>
  </header>

  <div class="sheet-body">

    <section class="top-grid">

      {{!-- INFOS --}}
      <div class="col card">
        <h2>Infos</h2>

        <div class="mm-line">
          <span class="mm-label">Poids (unité)</span>
          {{#if canEdit}}
            <input class="mm-input" type="number" name="system.poids" value="{{system.poids}}" step="0.1" min="0"/>
          {{else}}
            <div class="mm-value"><b>{{system.poids}}</b></div>
          {{/if}}
        </div>

        <div class="mm-line">
          <span class="mm-label">Main</span>
          {{#if canEdit}}
            <select class="mm-input" name="system.emplacement">
              <option value="mainDroite" {{#if (eq system.emplacement "mainDroite")}}selected{{/if}}>Main droite</option>
              <option value="mainGauche" {{#if (eq system.emplacement "mainGauche")}}selected{{/if}}>Main gauche</option>
            </select>
          {{else}}
            <div class="mm-value"><b>
              {{#if (eq system.emplacement "mainDroite")}}Main droite{{/if}}
              {{#if (eq system.emplacement "mainGauche")}}Main gauche{{/if}}
            </b></div>
          {{/if}}
        </div>

        <div class="mm-line">
          <span class="mm-label">Arme à 2 mains</span>
          {{#if canEdit}}
            <input type="checkbox" name="system.twoHands" value="1" {{#if system.twoHands}}checked{{/if}}/>
          {{else}}
            <div class="mm-value"><b>{{#if system.twoHands}}Oui{{else}}Non{{/if}}</b></div>
          {{/if}}
        </div>

        <div class="mm-line">
          <span class="mm-label">Difficulté</span>
          {{#if canEdit}}
            <input class="mm-input" type="number" name="system.difficulte" value="{{system.difficulte}}" min="0" max="4"/>
          {{else}}
            <div class="mm-value"><b>{{system.difficulte}}</b></div>
          {{/if}}
        </div>

        <p class="hint">
          Les dégâts réels sont : <b>bonus stat</b> + <b>dé</b> + <b>fixe</b> (+ effets).<br/>
          (Le calcul final est affiché au moment de l’attaque dans le chat.)
        </p>
      </div>

      {{!-- DEGATS --}}
      <div class="col card">
        <h2>Dégâts</h2>

        <div class="mm-line">
          <span class="mm-label">Type de dégâts</span>
          {{#if canEdit}}
            <select class="mm-input" name="system.livraison">
              <option value="physique" {{#if (eq system.livraison "physique")}}selected{{/if}}>Physique</option>
              <option value="magique" {{#if (eq system.livraison "magique")}}selected{{/if}}>Magique</option>
            </select>
          {{else}}
            <div class="mm-value"><b>{{system.livraison}}</b></div>
          {{/if}}
        </div>

        {{#if canEdit}}
          <div class="mm-line">
            <span class="mm-label">Dé de base</span>
            <input class="mm-input" type="text" name="system.damage.dice" value="{{system.damage.dice}}" placeholder="ex: 1d6"/>
          </div>

          <div class="mm-line">
            <span class="mm-label">Dégâts fixes</span>
            <input class="mm-input" type="number" name="system.damage.flat" value="{{system.damage.flat}}"/>
          </div>

          <div class="mm-line">
            <span class="mm-label">Scaling stat</span>
            <select class="mm-input" name="system.damage.scaling.stat">
              <option value="force" {{#if (eq system.damage.scaling.stat "force")}}selected{{/if}}>Force</option>
              <option value="intelligence" {{#if (eq system.damage.scaling.stat "intelligence")}}selected{{/if}}>Intelligence</option>
              <option value="dexterite" {{#if (eq system.damage.scaling.stat "dexterite")}}selected{{/if}}>Dextérité</option>
              <option value="acuite" {{#if (eq system.damage.scaling.stat "acuite")}}selected{{/if}}>Acuité</option>
              <option value="endurance" {{#if (eq system.damage.scaling.stat "endurance")}}selected{{/if}}>Endurance</option>
            </select>
          </div>

          <div class="mm-line">
            <span class="mm-label">Par</span>
            <input class="mm-input" type="number" name="system.damage.scaling.per" value="{{system.damage.scaling.per}}" min="1"/>
          </div>

          <div class="mm-line">
            <span class="mm-label">Gain / palier</span>
            <input class="mm-input" type="number" name="system.damage.scaling.perStep" value="{{system.damage.scaling.perStep}}"/>
          </div>
        {{else}}
          <div class="preview-block">
            <div><b>Dégâts :</b> {{ui.damageExpr}}</div>
            <div class="preview-sub">
              Bonus stat : <b>{{ui.damagePreview.scalingBonus}}</b> • Fixe : <b>{{ui.damagePreview.flat}}</b>
              {{#if ui.damagePreview.hasDice}}
                • Min/Max : <b>{{ui.damagePreview.min}}</b> - <b>{{ui.damagePreview.max}}</b>
              {{/if}}
            </div>
          </div>
        {{/if}}

        <div class="mm-line">
          <span class="mm-label">Portée (mètres)</span>
          {{#if canEdit}}
            <input class="mm-input" type="number" name="system.portee" value="{{system.portee}}" min="1"/>
          {{else}}
            <div class="mm-value"><b>{{system.portee}}</b></div>
          {{/if}}
        </div>

        <hr/>

        <h3>Critique</h3>

        {{!-- ✅ MODE SUPPRIMÉ --}}

        {{#if canEdit}}
          <div class="mm-line">
            <span class="mm-label">Dé extra</span>
            <input class="mm-input" type="text" name="system.crit.damage.dice" value="{{system.crit.damage.dice}}" placeholder="ex: 1d6"/>
          </div>

          <div class="mm-line">
            <span class="mm-label">Fixe extra</span>
            <input class="mm-input" type="number" name="system.crit.damage.flat" value="{{system.crit.damage.flat}}"/>
          </div>

          <div class="mm-line">
            <span class="mm-label">Scaling stat (crit)</span>
            <select class="mm-input" name="system.crit.damage.scaling.stat">
              <option value="force" {{#if (eq system.crit.damage.scaling.stat "force")}}selected{{/if}}>Force</option>
              <option value="intelligence" {{#if (eq system.crit.damage.scaling.stat "intelligence")}}selected{{/if}}>Intelligence</option>
              <option value="dexterite" {{#if (eq system.crit.damage.scaling.stat "dexterite")}}selected{{/if}}>Dextérité</option>
              <option value="acuite" {{#if (eq system.crit.damage.scaling.stat "acuite")}}selected{{/if}}>Acuité</option>
              <option value="endurance" {{#if (eq system.crit.damage.scaling.stat "endurance")}}selected{{/if}}>Endurance</option>
            </select>
          </div>

          <div class="mm-line">
            <span class="mm-label">Par (crit)</span>
            <input class="mm-input" type="number" name="system.crit.damage.scaling.per" value="{{system.crit.damage.scaling.per}}" min="1"/>
          </div>

          <div class="mm-line">
            <span class="mm-label">Gain / palier (crit)</span>
            <input class="mm-input" type="number" name="system.crit.damage.scaling.perStep" value="{{system.crit.damage.scaling.perStep}}"/>
          </div>
        {{else}}
          <div class="preview-block">
            <div><b>Crit :</b> {{ui.critExpr}}</div>
            <div class="preview-sub">
              Bonus stat : <b>{{ui.critPreview.scalingBonus}}</b> • Fixe : <b>{{ui.critPreview.flat}}</b>
              {{#if ui.critPreview.hasDice}}
                • Min/Max : <b>{{ui.critPreview.min}}</b> - <b>{{ui.critPreview.max}}</b>
              {{/if}}
            </div>
          </div>
        {{/if}}
      </div>
    </section>

    {{!-- BONUS --}}
    <section class="card">
      <h2>Bonus d’équipement</h2>
      <p class="hint">Ces bonus s’appliquent quand l’arme est équipée.</p>

      {{#if canEdit}}
        <div class="grid-mm">
          <div class="mm-line"><span class="mm-label">Force</span><input class="mm-input" type="number" name="system.bonus.force" value="{{system.bonus.force}}"/></div>
          <div class="mm-line"><span class="mm-label">Intelligence</span><input class="mm-input" type="number" name="system.bonus.intelligence" value="{{system.bonus.intelligence}}"/></div>
          <div class="mm-line"><span class="mm-label">Dextérité</span><input class="mm-input" type="number" name="system.bonus.dexterite" value="{{system.bonus.dexterite}}"/></div>
          <div class="mm-line"><span class="mm-label">Acuité</span><input class="mm-input" type="number" name="system.bonus.acuite" value="{{system.bonus.acuite}}"/></div>
          <div class="mm-line"><span class="mm-label">Endurance</span><input class="mm-input" type="number" name="system.bonus.endurance" value="{{system.bonus.endurance}}"/></div>

          <div class="mm-line"><span class="mm-label">PV max</span><input class="mm-input" type="number" name="system.bonus.pvMax" value="{{system.bonus.pvMax}}"/></div>
          <div class="mm-line"><span class="mm-label">Mana max</span><input class="mm-input" type="number" name="system.bonus.manaMax" value="{{system.bonus.manaMax}}"/></div>
          <div class="mm-line"><span class="mm-label">Régén PV</span><input class="mm-input" type="number" name="system.bonus.regenPv" value="{{system.bonus.regenPv}}"/></div>
          <div class="mm-line"><span class="mm-label">Régén Mana</span><input class="mm-input" type="number" name="system.bonus.regenMana" value="{{system.bonus.regenMana}}"/></div>
          <div class="mm-line"><span class="mm-label">Vitesse</span><input class="mm-input" type="number" name="system.bonus.vitesse" value="{{system.bonus.vitesse}}"/></div>

          <div class="mm-line"><span class="mm-label">Armure fixe</span><input class="mm-input" type="number" name="system.bonus.armureFixe" value="{{system.bonus.armureFixe}}"/></div>
          <div class="mm-line"><span class="mm-label">Résistance fixe</span><input class="mm-input" type="number" name="system.bonus.resistanceFixe" value="{{system.bonus.resistanceFixe}}"/></div>
          <div class="mm-line"><span class="mm-label">Score Armure</span><input class="mm-input" type="number" name="system.bonus.scoreArmure" value="{{system.bonus.scoreArmure}}"/></div>
          <div class="mm-line"><span class="mm-label">Score Résistance</span><input class="mm-input" type="number" name="system.bonus.scoreResistance" value="{{system.bonus.scoreResistance}}"/></div>

          <div class="mm-line"><span class="mm-label">Toucher physique</span><input class="mm-input" type="number" name="system.bonus.toucherPhysique" value="{{system.bonus.toucherPhysique}}"/></div>
          <div class="mm-line"><span class="mm-label">Toucher magique</span><input class="mm-input" type="number" name="system.bonus.toucherMagique" value="{{system.bonus.toucherMagique}}"/></div>
        </div>
      {{else}}
        {{#if displayWeaponBonuses.length}}
          <ul style="margin:0; padding-left:18px;">
            {{#each displayWeaponBonuses as |b|}}
              <li><b>{{b.label}}</b> : {{#if (gt b.value 0)}}+{{/if}}{{b.value}}</li>
            {{/each}}
          </ul>
        {{else}}
          <small style="opacity:.8;">Aucun bonus.</small>
        {{/if}}
      {{/if}}
    </section>

    {{!-- ETATS / EFFETS (MJ) --}}
    {{#if canEdit}}
      <section class="card">
        <h2>États / Effets</h2>
        <p class="hint">Définis les effets appliqués à la cible en cas de touche. (MJ)</p>

        <div class="row" style="gap:8px; flex-wrap:wrap; display:flex;">
          <button type="button" class="btn" data-action="addEffect">+ Ajouter un effet</button>
        </div>

        {{#if system.effects.length}}
          <ol class="items-list simple" style="margin-top:10px; padding-left:18px;">
            {{#each system.effects as |e idx|}}
              <li class="item" style="border:1px solid rgba(0,0,0,.12); border-radius:12px; padding:10px; margin-bottom:10px;">
                <div class="mm-line">
                  <span class="mm-label">Nom</span>
                  <input class="mm-input" type="text" name="system.effects.{{idx}}.label" value="{{e.label}}" />
                </div>

                <div class="grid-mm-3">
                  <div class="mm-line">
                    <span class="mm-label">Durée (tours)</span>
                    <input class="mm-input" type="number" name="system.effects.{{idx}}.duration" value="{{e.duration}}" min="0"/>
                  </div>
                  <div class="mm-line">
                    <span class="mm-label">Difficulté (retirer)</span>
                    <input class="mm-input" type="number" name="system.effects.{{idx}}.cleanseDC" value="{{e.cleanseDC}}" min="0" max="20"/>
                  </div>
                  <div class="mm-line">
                    <span class="mm-label">Stacking</span>
                    <select class="mm-input" name="system.effects.{{idx}}.stacking">
                      <option value="replace" {{#if (eq e.stacking "replace")}}selected{{/if}}>Remplace</option>
                      <option value="refresh" {{#if (eq e.stacking "refresh")}}selected{{/if}}>Refresh durée</option>
                      <option value="stack" {{#if (eq e.stacking "stack")}}selected{{/if}}>Cumule</option>
                    </select>
                  </div>
                </div>

                <hr style="margin:10px 0; opacity:.3"/>

                <h3 style="margin:0 0 6px;">DOT (optionnel)</h3>
                <div class="grid-mm-4">
                  <div class="mm-line"><span class="mm-label">Base</span><input class="mm-input" type="number" name="system.effects.{{idx}}.dot.base" value="{{e.dot.base}}" /></div>
                  <div class="mm-line">
                    <span class="mm-label">Stat source</span>
                    <select class="mm-input" name="system.effects.{{idx}}.dot.stat">
                      <option value="force" {{#if (eq e.dot.stat "force")}}selected{{/if}}>Force</option>
                      <option value="intelligence" {{#if (eq e.dot.stat "intelligence")}}selected{{/if}}>Intelligence</option>
                      <option value="dexterite" {{#if (eq e.dot.stat "dexterite")}}selected{{/if}}>Dextérité</option>
                      <option value="acuite" {{#if (eq e.dot.stat "acuite")}}selected{{/if}}>Acuité</option>
                      <option value="endurance" {{#if (eq e.dot.stat "endurance")}}selected{{/if}}>Endurance</option>
                    </select>
                  </div>
                  <div class="mm-line"><span class="mm-label">Par</span><input class="mm-input" type="number" name="system.effects.{{idx}}.dot.per" value="{{e.dot.per}}" min="1" /></div>
                  <div class="mm-line">
                    <span class="mm-label">Type dégâts</span>
                    <select class="mm-input" name="system.effects.{{idx}}.dot.livraison">
                      <option value="physique" {{#if (eq e.dot.livraison "physique")}}selected{{/if}}>Physique</option>
                      <option value="magique" {{#if (eq e.dot.livraison "magique")}}selected{{/if}}>Magique</option>
                    </select>
                  </div>
                </div>

                <div class="row" style="justify-content:flex-end; margin-top:8px; display:flex;">
                  <button type="button" class="btn small" data-action="removeEffect" data-idx="{{idx}}">Supprimer</button>
                </div>
              </li>
            {{/each}}
          </ol>
        {{else}}
          <p class="hint">Aucun effet défini.</p>
        {{/if}}
      </section>
    {{/if}}

    {{!-- PRIX (MJ ONLY) --}}
    {{#if canEdit}}
      <section class="card">
        <h2>Prix (MJ)</h2>
        <div class="resource-grid" style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:10px;">
          <div><label>Cuivre</label><input class="mm-input" type="number" name="system.prix.cuivre" value="{{system.prix.cuivre}}" min="0"/></div>
          <div><label>Argent</label><input class="mm-input" type="number" name="system.prix.argent" value="{{system.prix.argent}}" min="0"/></div>
          <div><label>Or</label><input class="mm-input" type="number" name="system.prix.or" value="{{system.prix.or}}" min="0"/></div>
        </div>
        <small style="opacity:0.85;">100 cuivre = 1 argent • 100 argent = 1 or</small>
      </section>
    {{/if}}

    {{!-- RECETTE ASSOCIÉE --}}
    {{#if canEdit}}
      <section class="card">
        <h2>Recette associée</h2>
        <div class="mm-line">
          <span class="mm-label">UUID</span>
          <input class="mm-input" type="text" name="system.recetteAssociee.uuid" value="{{system.recetteAssociee.uuid}}"
            placeholder="Clic droit sur recette → Copy UUID" />
        </div>
        <div class="mm-line">
          <span class="mm-label">Nom (info)</span>
          <input class="mm-input" type="text" name="system.recetteAssociee.name" value="{{system.recetteAssociee.name}}"
            placeholder="Nom affiché de la recette" />
        </div>
        {{#if system.recetteAssociee.uuid}}
        <button type="button" class="rpg-open-uuid" data-uuid="{{system.recetteAssociee.uuid}}"
          style="margin-top:6px;cursor:pointer;padding:3px 10px;border-radius:5px;font-size:12px">
          📜 Voir la recette
        </button>
        {{/if}}
        <div style="margin-top:8px;">
          <label>Vendeur associé</label>
          <input type="text" name="system.vendeurAssocie" value="{{system.vendeurAssocie}}" placeholder="Nom du marchand ou du monstre" style="width:100%"/>
        </div>
      </section>
    {{/if}}

    {{!-- RÉSISTANCES (MJ ONLY) --}}
    {{#if canEdit}}
      <section class="card">
        <h2>Résistances aux effets</h2>
        <div class="rpg-resistances">
          {{#each system.resistances as |r idx|}}
          <div class="resistance-row" data-idx="{{idx}}" style="display:flex;gap:6px;align-items:center;margin-bottom:4px">
            <select name="system.resistances.{{idx}}.tag" style="flex:1.5">
              {{#each ../EFFECT_TAGS as |label tag|}}
                <option value="{{tag}}" {{#if (eq r.tag tag)}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <input type="text" name="system.resistances.{{idx}}.effectKey" value="{{r.effectKey}}"
              placeholder="Effet précis (ex: Brûlure) — vide = tout le type" style="flex:1.5;font-size:11px"/>
            <label style="font-size:11px;white-space:nowrap">Durée -<input type="number" name="system.resistances.{{idx}}.durationReduction" value="{{r.durationReduction}}" min="0" style="width:50px"/></label>
            <label style="font-size:11px;white-space:nowrap">DOT -<input type="number" name="system.resistances.{{idx}}.dotReductionPct" value="{{r.dotReductionPct}}" min="0" max="100" style="width:50px"/>%</label>
            <label style="font-size:11px;white-space:nowrap"><input type="checkbox" name="system.resistances.{{idx}}.immune" {{#if r.immune}}checked{{/if}}/> Immunité</label>
            <button type="button" data-action="removeResistance" data-idx="{{idx}}" title="Retirer">✕</button>
          </div>
          {{/each}}
        </div>
        <button type="button" data-action="addResistance" style="margin-top:4px">+ Ajouter une résistance</button>
        <div style="font-size:11px;opacity:0.8;margin-top:4px">
          Réduit la durée et/ou les dégâts par tour des effets portant le tag choisi.
        </div>
      </section>
    {{/if}}

    {{!-- DESCRIPTION --}}
    <section class="card">
      <h2>Description</h2>
      {{#if canEdit}}
        <textarea name="system.description" rows="5">{{system.description}}</textarea>
      {{else}}
        {{#if system.description}}
          <div style="white-space:pre-wrap;"><b>{{system.description}}</b></div>
        {{else}}
          <small style="opacity:.85;">—</small>
        {{/if}}
      {{/if}}
    </section>

  </div>
</div>