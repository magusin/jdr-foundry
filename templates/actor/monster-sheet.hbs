<form class="rpg-sheet sheet actor monster-sheet" autocomplete="off">
  <header class="sheet-header">
    <div style="display:flex;gap:10px;align-items:center">
      {{#if canSeeStats}}
      <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
        <img class="profile rpg-img-edit" src="{{actor.img}}" data-field="img"
          title="Cliquer pour changer le portrait" height="64" width="64"
          style="cursor:pointer;border-radius:8px;border:2px solid var(--color-border-light-2)" />
        <small style="font-size:9px;opacity:.7">Portrait</small>
      </div>
      <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
        <img class="profile rpg-img-edit" src="{{actor.prototypeToken.texture.src}}" data-field="prototypeToken.texture.src"
          title="Cliquer pour changer l'image du token" height="64" width="64"
          style="cursor:pointer;border-radius:8px;border:2px solid var(--color-border-light-2);object-fit:cover" />
        <small style="font-size:9px;opacity:.7">Token</small>
      </div>
      {{else}}
      <img class="profile" src="{{actor.img}}" height="64" width="64" style="border-radius:8px" />
      {{/if}}
      <h1 style="flex:1">
        <input name="name" type="text" value="{{actor.name}}" {{#unless canSeeStats}}disabled{{/unless}} />
      </h1>
    </div>
  </header>

  <nav class="sheet-tabs tabs">
    <a class="item active" data-tab="main">Monstre</a>
    {{#if canSeeStats}}
    <a class="item" data-tab="attacks">Attaques</a>
    {{/if}}
    {{#if showGenConfig}}
    <a class="item" data-tab="butin">Butin</a>
    <a class="item" data-tab="gen">Génération (MJ)</a>
    {{/if}}
  </nav>

  <section class="sheet-body">

    <div class="tab" data-tab="main" style="display:block;">

      {{#unless canSeeStats}}
      <section class="card">
        <h2>Description</h2>
        <div class="rp-text">{{system.description}}</div>
      </section>
      {{/unless}}

      {{#if canSeeStats}}
      <div class="rpg-grid-2">

        <section class="card">
          <h2>Informations</h2>
          <div class="grid-mm">
            <div class="mm-line">
              <span>Niveau</span>
              <input type="number" name="system.niveau" value="{{system.niveau}}" min="1" />
            </div>
            <div class="mm-line">
              <span>XP donnée</span>
              <input type="number" name="system.recompenses.xp" value="{{system.recompenses.xp}}" min="0" />
            </div>
            <div class="mm-line">
              <span>Butin (RollTable UUID, optionnel)</span>
              <div style="display:flex;gap:6px;align-items:center">
                <input type="text" name="system.butin.tableUuid" value="{{system.butin.tableUuid}}"
                  placeholder="UUID table Foundry (optionnel)" style="flex:1;font-size:11px" />
                {{#if system.butin.tableUuid}}
                <button type="button" class="rpg-open-uuid" data-uuid="{{system.butin.tableUuid}}"
                  style="cursor:pointer;padding:1px 6px;font-size:10px;white-space:nowrap">📄</button>
                {{/if}}
              </div>
            </div>
          </div>
          {{#if showGenConfig}}
          <button type="button" class="btn" data-action="rerollMonster" style="margin-top:10px;width:100%;">
            🎲 Régénérer les stats (selon le niveau actuel)
          </button>
          <small class="muted">Retire de nouvelles valeurs aléatoires dans les bands du niveau ci-dessus.</small>
          {{/if}}
          {{#if hasLoot}}
          <button type="button" data-action="lootThisMonster" style="margin-top:8px;width:100%;padding:5px;cursor:pointer;border-radius:6px;font-weight:600">
            🎁 Looter ce monstre
          </button>
          {{/if}}
        </section>

        <section class="card">
          <h2>Combat — PV</h2>
          <div class="resource-block">
            <div class="resource-head">
              <div class="resource-title">PV</div>
              <div class="resource-meta">
                {{system.derived.hp.pct}}% — {{system.derived.hp.etat}}
              </div>
            </div>
            <div class="resource-row">
              <input class="num sm" type="number" name="system.ressources.pv.valeur"
                value="{{system.ressources.pv.valeur}}" min="0" />
              <span class="sep">/</span>
              <b style="margin-left:6px;">{{system.ressources.pv.max}}</b>
              <span class="muted" style="margin-left:8px;">(base {{system.base.pvMax}})</span>
            </div>
            <div class="hp-btn-row">
              <button type="button" class="btn" data-action="hpPlus" data-delta="5">+5 PV</button>
              <button type="button" class="btn" data-action="hpPlus" data-delta="1">+1 PV</button>
              <button type="button" class="btn" data-action="hpPlus" data-delta="-1">-1 PV</button>
              <button type="button" class="btn" data-action="hpPlus" data-delta="-5">-5 PV</button>
            </div>
            <div style="margin-top:8px;font-size:12px;">
              {{#if system.derived.ko}}<b style="color:#c0392b">💀 K.O. — ne peut plus agir</b>{{else}}<span class="muted">Actif</span>{{/if}}
            </div>
            <label style="font-size:11px;display:flex;align-items:center;gap:6px;margin-top:4px">
              <input type="checkbox" name="system.ignoreKO" {{#if system.ignoreKO}}checked{{/if}} />
              Ignorer l'incapacité à 0 PV (exception)
            </label>
          </div>
        </section>

        <section class="card">
          <h2>Caractéristiques (valeurs effectives)</h2>
          <div class="grid-mm">
            <div class="mm-line"><span>Force</span><b>{{system.derived.effective.principales.force}}</b></div>
            <div class="mm-line"><span>Intelligence</span><b>{{system.derived.effective.principales.intelligence}}</b></div>
            <div class="mm-line"><span>Dextérité</span><b>{{system.derived.effective.principales.dexterite}}</b></div>
            <div class="mm-line"><span>Acuité</span><b>{{system.derived.effective.principales.acuite}}</b></div>
            <div class="mm-line"><span>Endurance</span><b>{{system.derived.effective.principales.endurance}}</b></div>
          </div>
          <small class="muted">Tirées par la génération aléatoire — modifiables dans "Ajustement manuel" ci-dessous si besoin.</small>
        </section>

        <section class="card">
          <h2>Défenses (valeurs effectives)</h2>
          <div class="grid-mm">
            <div class="mm-line"><span>Armure fixe</span><b>{{system.derived.effective.defenses.armureFixe}}</b></div>
            <div class="mm-line"><span>Résistance fixe</span><b>{{system.derived.effective.defenses.resistanceFixe}}</b></div>
            <div class="mm-line"><span>Score Armure</span><b>{{system.derived.effective.defenses.scoreArmure}}</b></div>
            <div class="mm-line"><span>Score Résistance</span><b>{{system.derived.effective.defenses.scoreResistance}}</b></div>
            <div class="mm-line"><span>Réduction phys.</span><b>{{system.derived.reductions.physiquePct}}%</b></div>
            <div class="mm-line"><span>Réduction mag.</span><b>{{system.derived.reductions.magiquePct}}%</b></div>
          </div>
        </section>

        <details class="card" style="grid-column: 1 / -1;">
          <summary style="cursor:pointer;font-weight:600;padding:4px 0;">⚙️ Ajustement manuel (avancé — écrase les valeurs tirées par la génération)</summary>
          <div class="grid-mm" style="margin-top:10px;">
            <div class="mm-line">
              <span>Vitesse (base)</span>
              <input type="number" name="system.base.vitesse" value="{{system.base.vitesse}}" min="0" />
              <span class="muted" style="margin-left:8px;">eff: {{system.deplacement.vitesse}}</span>
            </div>
            <div class="mm-line">
              <span>PV max (base)</span>
              <input class="num sm" type="number" name="system.base.pvMax" value="{{system.base.pvMax}}" min="1" />
            </div>
            <div class="mm-line">
              <span>Régén PV (base)</span>
              <input class="regen-input" type="number" name="system.base.regenPv" value="{{system.base.regenPv}}" />
              <span class="muted" style="margin-left:8px;">eff: {{system.regeneration.pv}}</span>
            </div>
            <div class="mm-line">
              <span>Force</span>
              <input type="number" name="system.principales.force" value="{{system.principales.force}}" min="0" />
            </div>
            <div class="mm-line">
              <span>Intelligence</span>
              <input type="number" name="system.principales.intelligence" value="{{system.principales.intelligence}}" min="0" />
            </div>
            <div class="mm-line">
              <span>Dextérité</span>
              <input type="number" name="system.principales.dexterite" value="{{system.principales.dexterite}}" min="0" />
            </div>
            <div class="mm-line">
              <span>Acuité</span>
              <input type="number" name="system.principales.acuite" value="{{system.principales.acuite}}" min="0" />
            </div>
            <div class="mm-line">
              <span>Endurance</span>
              <input type="number" name="system.principales.endurance" value="{{system.principales.endurance}}" min="0" />
            </div>
            <div class="mm-line">
              <span>Armure fixe</span>
              <input type="number" name="system.defenses.armureFixe" value="{{system.defenses.armureFixe}}" min="0" />
            </div>
            <div class="mm-line">
              <span>Résistance fixe</span>
              <input type="number" name="system.defenses.resistanceFixe" value="{{system.defenses.resistanceFixe}}" min="0" />
            </div>
            <div class="mm-line">
              <span>Score Armure</span>
              <input type="number" name="system.defenses.scoreArmure" value="{{system.defenses.scoreArmure}}" min="0" />
            </div>
            <div class="mm-line">
              <span>Score Résistance</span>
              <input type="number" name="system.defenses.scoreResistance" value="{{system.defenses.scoreResistance}}" min="0" />
            </div>
          </div>
        </details>

        <section class="panel-states" style="grid-column: 1 / -1;">
          <header class="panel-title">
            <h2>États</h2>
            {{#if flags.isGM}}
            <button type="button" data-action="stateAdd">+ Ajouter</button>
            {{/if}}
          </header>
          <ul class="state-list">
            {{#each system.etatsActifs as |e|}}
            <li class="state-row" data-state-id="{{e.id}}">
              <div class="state-main">
                <b>{{e.label}}</b>
                {{#if e.isAura}}<span class="muted" style="margin-left:6px;">🌀</span>{{/if}}
                {{#if e.isBeneficial}}<span class="muted" style="margin-left:6px;">✨</span>{{/if}}
                {{#if e.isHarmful}}<span class="muted" style="margin-left:6px;">☠️</span>{{/if}}
                <span class="muted">({{e.remaining}} tour{{#unless (eq e.remaining 1)}}s{{/unless}})</span>
                {{#if e.cleanseDC}}<span class="muted">Retrait: {{e.cleanseDC}}+</span>{{/if}}
                {{#if e.summary}}<div class="muted" style="margin-top:4px;">{{e.summary}}</div>{{/if}}
              </div>
              <div class="state-actions">
                {{#if ../flags.isGM}}
                <button type="button" data-action="stateEdit" data-id="{{e.id}}">✎</button>
                <button type="button" data-action="stateDelete" data-id="{{e.id}}">🗑</button>
                {{/if}}
                <button type="button" data-action="stateShow" data-id="{{e.id}}">?</button>
              </div>
            </li>
            {{/each}}
          </ul>
        </section>

          <section class="card" style="grid-column: 1 / -1;">
  <h2>Description</h2>
  <textarea name="system.description" rows="6" style="width:100%; resize:vertical; box-sizing:border-box;">{{system.description}}</textarea>
</section>

      </div>
      {{/if}}
    </div>

    {{#if canSeeStats}}
    <div class="tab" data-tab="attacks" style="display:none;">
      <section class="card">
        <h2>Armes & Sorts du monstre</h2>
        <p class="hint">Astuce : glisse-dépose une arme/sort depuis ton compendium vers cette fiche.</p>
        {{#if itemsAttaques.length}}
        <ol class="items-list simple">
          {{#each itemsAttaques as |it|}}
          <li class="item" data-item-id="{{it._id}}">
            <span class="name">
              <img src="{{it.img}}" alt="" />
              <a class="item-edit">{{it.name}}</a>
              <small>
                {{#if it._ui.kindIcon}}{{it._ui.kindIcon}}{{/if}}
                {{#if it._ui.livraison}}({{it._ui.livraison}}){{/if}}
                {{#if it._ui.coutMana}} — Mana: {{it._ui.coutMana}}{{/if}}
                {{#if it._ui.rangeMax}} — Portée: {{it._ui.rangeMin}}–{{it._ui.rangeMax}}{{/if}}
                {{#if it._ui.difficulte}} — Diff: +{{it._ui.difficulte}}{{/if}}
                {{#if it._ui.cdMax}} — CD: {{it._ui.cdRestant}}/{{it._ui.cdMax}}{{/if}}
                {{#if it._ui.damageDice}} — Dégâts: {{it._ui.damageDice}}{{/if}}
              </small>
            </span>
            <div class="item-controls">
              <a class="btn" data-action="useItem" data-item-id="{{it._id}}">Déclarer</a>
              {{#if (eq it.type "spell")}}
              <a class="btn" data-action="castSpell" data-item-id="{{it._id}}">
                {{#if it.system.aura.active}}Désactiver{{else}}Lancer{{/if}}
              </a>
              {{/if}}
              <a class="btn" data-action="deleteItem" data-item-id="{{it._id}}">🗑</a>
            </div>
          </li>
          {{/each}}
        </ol>
        {{else}}
        <p class="hint">Aucune arme/sort sur ce monstre.</p>
        {{/if}}
      </section>
    </div>
    {{/if}}

    {{#if showGenConfig}}
    <div class="tab" data-tab="butin" style="display:none;">
      <section class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
          <h2>🎁 Butin de ce monstre</h2>
          <button type="button" data-action="addLootEntry" style="cursor:pointer;padding:2px 10px">+ Item</button>
        </div>
        <div style="font-size:11px;opacity:.6;margin-bottom:8px">
          Chaque item a une probabilité (%) d'être lâché. Qté min/max = quantité tirée aléatoirement.
        </div>

        {{#each system.butin.entries as |entry idx|}}
        <div class="loot-entry" data-idx="{{idx}}"
          style="display:grid;grid-template-columns:32px 1fr 60px 55px 55px 32px;gap:4px;align-items:center;margin-bottom:6px;padding:6px;background:rgba(255,255,255,0.03);border-radius:6px">
          <img src="{{entry.img}}" alt="" style="width:28px;height:28px;border-radius:5px;object-fit:cover"/>
          <div>
            {{#if entry.uuid}}
            <button type="button" class="rpg-open-uuid" data-uuid="{{entry.uuid}}"
              style="cursor:pointer;font-weight:600;background:none;border:none;text-align:left;color:inherit;font-size:13px;padding:0">
              {{entry.name}}
            </button>
            {{else}}
            <input type="text" name="system.butin.entries.{{idx}}.uuid"
              value="{{entry.uuid}}" placeholder="UUID de l'item" style="font-size:11px;width:100%"/>
            {{/if}}
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;gap:1px">
            <small style="font-size:9px;opacity:.6">Chance %</small>
            <input type="number" name="system.butin.entries.{{idx}}.pct" value="{{entry.pct}}" min="1" max="100" style="width:54px;font-size:12px;text-align:center"/>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;gap:1px">
            <small style="font-size:9px;opacity:.6">Qté/drop</small>
            <input type="number" name="system.butin.entries.{{idx}}.qty" value="{{entry.qty}}" min="1" style="width:48px;font-size:12px;text-align:center"/>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;gap:1px">
            <small style="font-size:9px;opacity:.6">Essais</small>
            <input type="number" name="system.butin.entries.{{idx}}.tries" value="{{entry.tries}}" min="1" style="width:48px;font-size:12px;text-align:center"/>
          </div>
          <button type="button" data-action="removeLootEntry" data-idx="{{idx}}"
            style="cursor:pointer;color:#c0392b;background:none;border:none;font-size:16px;line-height:1">✕</button>
        </div>
        {{else}}
        <div style="opacity:.4;text-align:center;padding:20px;font-size:13px">
          Aucun butin configuré. Clique "+ Item" pour ajouter des drops.
        </div>
        {{/each}}

        <div style="margin-top:12px;padding-top:10px;border-top:1px solid rgba(255,255,255,0.1)">
          <div style="font-size:11px;opacity:.5;margin-bottom:4px">Table Foundry (optionnel, pour compat.)</div>
          <div style="display:flex;gap:6px;align-items:center">
            <input type="text" name="system.butin.tableUuid" value="{{system.butin.tableUuid}}"
              placeholder="UUID RollTable Foundry" style="flex:1;font-size:11px;opacity:.7" />
            {{#if system.butin.tableUuid}}
            <button type="button" class="rpg-open-uuid" data-uuid="{{system.butin.tableUuid}}"
              style="cursor:pointer;padding:1px 6px;font-size:10px">📄</button>
            {{/if}}
          </div>
        </div>
      </section>
    </div>

    <div class="tab" data-tab="gen" style="display:none;">
      <section class="card gen-card">
        <h2>🎲 Configuration aléatoire</h2>
        <div class="gen-toolbar">
          <label>Niveaux possibles</label>
          <input type="text" name="system.gen.levelsCsv" value="{{system.gen.levelsCsv}}" placeholder="Ex: 2,4,6" />
          <button type="button" class="btn small" data-action="genInitBands">+ Initialiser les niveaux</button>
        </div>

        {{#if genBands.length}}
        <div class="gen-levels">
          {{#each genBands as |b|}}
          <details class="gen-level-card" open>
            <summary>Niveau {{b.lvl}}</summary>

            <div class="gen-level-body">

              <div class="gen-group">
                <h4>Caractéristiques</h4>
                <div class="gen-pair-grid">
                  <div class="gen-pair">
                    <label>Force</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.stats.force.0" value="{{b.force.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.stats.force.1" value="{{b.force.max}}" />
                  </div>
                  <div class="gen-pair">
                    <label>Intelligence</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.stats.intelligence.0" value="{{b.intelligence.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.stats.intelligence.1" value="{{b.intelligence.max}}" />
                  </div>
                  <div class="gen-pair">
                    <label>Dextérité</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.stats.dexterite.0" value="{{b.dexterite.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.stats.dexterite.1" value="{{b.dexterite.max}}" />
                  </div>
                  <div class="gen-pair">
                    <label>Acuité</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.stats.acuite.0" value="{{b.acuite.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.stats.acuite.1" value="{{b.acuite.max}}" />
                  </div>
                  <div class="gen-pair">
                    <label>Endurance</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.stats.endurance.0" value="{{b.endurance.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.stats.endurance.1" value="{{b.endurance.max}}" />
                  </div>
                </div>
              </div>

              <div class="gen-group">
                <h4>Défenses</h4>
                <div class="gen-pair-grid">
                  <div class="gen-pair">
                    <label>Armure fixe</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.defenses.armureFixe.0" value="{{b.armureFixe.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.defenses.armureFixe.1" value="{{b.armureFixe.max}}" />
                  </div>
                  <div class="gen-pair">
                    <label>Résistance fixe</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.defenses.resistanceFixe.0" value="{{b.resistanceFixe.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.defenses.resistanceFixe.1" value="{{b.resistanceFixe.max}}" />
                  </div>
                  <div class="gen-pair">
                    <label>Score Armure</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.defenses.scoreArmure.0" value="{{b.scoreArmure.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.defenses.scoreArmure.1" value="{{b.scoreArmure.max}}" />
                  </div>
                  <div class="gen-pair">
                    <label>Score Résistance</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.defenses.scoreResistance.0" value="{{b.scoreResistance.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.defenses.scoreResistance.1" value="{{b.scoreResistance.max}}" />
                  </div>
                </div>
              </div>

              <div class="gen-group">
                <h4>Combat (secondaires)</h4>
                <div class="gen-pair-grid">
                  <div class="gen-pair">
                    <label>Toucher physique</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.toucherPhysique.0" value="{{b.toucherPhysique.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.toucherPhysique.1" value="{{b.toucherPhysique.max}}" />
                  </div>
                  <div class="gen-pair">
                    <label>Toucher magique</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.toucherMagique.0" value="{{b.toucherMagique.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.toucherMagique.1" value="{{b.toucherMagique.max}}" />
                  </div>
                  <div class="gen-pair">
                    <label>Fatigue max</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.fatigueMax.0" value="{{b.fatigueMax.min}}" min="0" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.fatigueMax.1" value="{{b.fatigueMax.max}}" min="0" />
                  </div>
                </div>
                <small class="muted">Toucher : peut être négatif (monstre maladroit) ou positif (monstre précis).</small>
              </div>

              <div class="gen-group">
                <h4>Ressources &amp; Récompense</h4>
                <div class="gen-pair-grid">
                  <div class="gen-pair">
                    <label>PV</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.pv.0" value="{{b.pv.min}}" min="1" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.pv.1" value="{{b.pv.max}}" min="1" />
                  </div>
                  <div class="gen-pair">
                    <label>Régén PV</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.regenPv.0" value="{{b.regenPv.min}}" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.regenPv.1" value="{{b.regenPv.max}}" />
                  </div>
                  <div class="gen-pair">
                    <label>Vitesse</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.vitesse.0" value="{{b.vitesse.min}}" min="0" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.vitesse.1" value="{{b.vitesse.max}}" min="0" />
                  </div>
                  <div class="gen-pair">
                    <label>XP donnée</label>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.xpReward.0" value="{{b.xpReward.min}}" min="0" />
                    <span class="sep">–</span>
                    <input class="num sm" type="number" name="system.gen.bands.{{b.lvl}}.xpReward.1" value="{{b.xpReward.max}}" min="0" />
                  </div>
                </div>
              </div>

            </div>
          </details>
          {{/each}}
        </div>
        {{else}}
        <p class="hint">Aucun niveau détecté. Renseigne <b>levelsCsv</b> (ex: 2,4,6) puis clique "Initialiser".</p>
        {{/if}}
      </section>
    </div>
    {{/if}}

  </section>
</form>