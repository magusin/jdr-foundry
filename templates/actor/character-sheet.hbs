<div class="{{cssClass}} rpg-sheet" autocomplete="off">

  {{!-- =========================
  HEADER
  ========================== --}}
  <header class="sheet-header" id="rpg-header-{{actor.id}}">
    <div class="header-left">
      <div style="display:flex;gap:6px;align-items:flex-start">
        <div style="display:flex;flex-direction:column;align-items:center;gap:2px">
          <img class="profile-img rpg-img-edit" src="{{actor.img}}" data-field="img"
            title="Cliquer pour changer le portrait" style="cursor:pointer" />
          <small style="font-size:9px;opacity:.6">Portrait</small>
        </div>
        {{#unless flags.readOnly}}
        <div style="display:flex;flex-direction:column;align-items:center;gap:2px">
          <img class="rpg-img-edit" src="{{actor.prototypeToken.texture.src}}" data-field="prototypeToken.texture.src"
            title="Cliquer pour changer l'image du token"
            style="width:48px;height:48px;cursor:pointer;border-radius:6px;border:1px solid var(--color-border-light-2);object-fit:cover" />
          <small style="font-size:9px;opacity:.6">Token</small>
        </div>
        {{/unless}}
      </div>

      <div class="header-meta">
        <input class="name" name="name" type="text" value="{{actor.name}}" placeholder="Nom" {{#if
          flags.readOnly}}disabled{{/if}} />

        <div class="meta-row">
          <div class="meta">
            <label>Niveau</label>
            <input type="number" name="system.niveau" value="{{system.niveau}}" min="1" {{#if
              flags.readOnly}}disabled{{/if}} />
          </div>

          <div class="meta" style="grid-column: 1 / -1;">
            <label>Expérience</label>

            <div style="display:flex; align-items:center; gap:10px;">
              <div
                style="flex:1; height:10px; background: rgba(255,255,255,0.12); border-radius:999px; overflow:hidden;">
                <div style="height:100%; width: {{calc.xpPct}}%; background: rgba(255,255,255,0.55);"></div>
              </div>
              <small>{{calc.xpValeur}} / {{calc.xpPalier}} ({{calc.xpPct}}%)</small>
            </div>

            {{#if flags.isGM}}
            <div style="margin-top:8px;">
              <label>XP actuelle</label>
              <input type="number" name="system.xp.valeur" value="{{system.xp.valeur}}" min="0" />
            </div>
            {{/if}}
          </div>

          <div class="meta">
            <label>Vitesse</label>
            <input type="number" name="system.base.vitesse" value="{{system.base.vitesse}}" min="0" {{#if
              flags.readOnly}}disabled{{/if}} />
          </div>
        </div>

        <div class="meta-row">
          <div class="meta">
            <label>Pods max</label>
            <input type="number" name="system.charge.podsMax" value="{{system.charge.podsMax}}" min="0" {{#if
              flags.readOnly}}disabled{{/if}} />
          </div>

          <div class="meta">
            <label>Pods actuels</label>
            <input type="number" name="system.charge.podsActuels" value="{{system.charge.podsActuels}}" min="0"
              step="0.1" disabled />
          </div>
        </div>

        <div class="encumbrance">
          <div class="enc-label {{charge.cssSurcharge}}">
            <span>Charge
              <span class="enc-badge {{charge.cssBadge}}">{{charge.etat}}</span>
            </span>
            <span>{{charge.podsActuels}} / {{charge.podsMax}} ({{charge.pct}}%)</span>
          </div>
          <div class="enc-bar">
            <div class="enc-fill {{charge.cssFill}}" style="width: {{charge.pctCapped}}%;"></div>
          </div>
          {{#if system.derived.surcharge}}
          <div class="state-badge state-badge--orange">🏋️ Surchargé — -1 vitesse</div>
          {{/if}}
        </div>
      </div>
    </div>

    <div class="header-right">
      <div class="resource">
        <div class="resource-label">
          <span>PV</span>
          <span class="resource-value">
            {{system.ressources.pv.valeur}} /
            {{#if system.derived.effective.ressources.pvMax}}
            {{system.derived.effective.ressources.pvMax}}
            {{else}}
            {{system.ressources.pv.max}}
            {{/if}}
          </span>
        </div>

        <div class="resource-grid">
          <input type="number" name="system.ressources.pv.valeur" value="{{system.ressources.pv.valeur}}" min="0" {{#if
            flags.readOnly}}disabled{{/if}} />
          <span>/</span>
          <input type="number" name="system.ressources.pv.max"
            value="{{#if system.derived.effective.ressources.pvMax}}{{system.derived.effective.ressources.pvMax}}{{else}}{{system.ressources.pv.max}}{{/if}}"
            min="0" {{#if flags.readOnly}}disabled{{/if}} />
        </div>

        {{#if flags.isGM}}
        <div style="display:flex; gap:6px; margin-top:6px;">
          <button type="button" class="btn small" data-action="adjRes" data-res="pv" data-delta="-5">-5</button>
          <button type="button" class="btn small" data-action="adjRes" data-res="pv" data-delta="-1">-1</button>
          <button type="button" class="btn small" data-action="adjRes" data-res="pv" data-delta="1">+1</button>
          <button type="button" class="btn small" data-action="adjRes" data-res="pv" data-delta="5">+5</button>
        </div>
        {{/if}}

        <div class="resource-sub">
          <label>Régén PV</label>
          <input type="number" name="system.regeneration.pv" value="{{system.regeneration.pv}}" {{#if
            flags.readOnly}}disabled{{/if}} />
        </div>

        <div>
          {{system.derived.hp.pct}}% — {{system.derived.hp.etat}}
        </div>
      </div>

      <div class="resource">
        <div class="resource-label">
          <span>Mana</span>
          <span class="resource-value">
            {{system.ressources.mana.valeur}} /
            {{#if system.derived.effective.ressources.manaMax}}
            {{system.derived.effective.ressources.manaMax}}
            {{else}}
            {{system.ressources.mana.max}}
            {{/if}}
          </span>
        </div>

        <div class="resource-grid">
          <input type="number" name="system.ressources.mana.valeur" value="{{system.ressources.mana.valeur}}" min="0"
            {{#if flags.readOnly}}disabled{{/if}} />

          <span class="sep">/</span>

          <input type="number" name="system.ressources.mana.max"
            value="{{#if system.derived.effective.ressources.manaMax}}{{system.derived.effective.ressources.manaMax}}{{else}}{{system.ressources.mana.max}}{{/if}}"
            min="0" {{#if flags.readOnly}}disabled{{/if}} />
        </div>

        {{#if flags.isGM}}
        <div style="display:flex; gap:6px; margin-top:6px;">
          <button type="button" class="btn small" data-action="adjRes" data-res="mana" data-delta="-5">-5</button>
          <button type="button" class="btn small" data-action="adjRes" data-res="mana" data-delta="-1">-1</button>
          <button type="button" class="btn small" data-action="adjRes" data-res="mana" data-delta="1">+1</button>
          <button type="button" class="btn small" data-action="adjRes" data-res="mana" data-delta="5">+5</button>
        </div>
        {{/if}}

        <div class="resource-sub">
          <label>Régén Mana</label>
          <input type="number" name="system.regeneration.mana" value="{{system.regeneration.mana}}" {{#if
            flags.readOnly}}disabled{{/if}} />
        </div>
      </div>

      {{!-- Fatigue --}}
      <div class="resource" style="grid-column: 1 / -1;">
        <div class="resource-label">
          <span>😴 Fatigue</span>
          <span class="resource-value">
            {{system.ressources.fatigue.valeur}} / {{system.ressources.fatigue.max}}
            {{#if system.derived.epuise}}<b style="color:#c0392b">— ÉPUISÉ (−10% stats)</b>{{/if}}
          </span>
        </div>
        <div class="enc-bar">
          <div class="enc-fill {{#if system.derived.epuise}}enc-surcharge{{/if}}"
               style="width: {{system.ressources.fatigue.pct}}%;"></div>
        </div>
        {{#if system.derived.epuise}}
        <div class="state-badge state-badge--red">😴 Fatigué — -10% stats, -1 vitesse</div>
        {{/if}}
      </div>

      {{!-- État K.O. (MJ only) --}}
      {{#if flags.isGM}}
      <div class="resource" style="grid-column: 1 / -1;">
        <div class="resource-label">
          <span>💀 K.O.</span>
          <span class="resource-value">
            {{#if system.derived.ko}}<b style="color:#c0392b">Ne peut pas agir ce tour</b>{{else}}<span class="muted">Actif</span>{{/if}}
          </span>
        </div>
        <label style="font-size:11px;display:flex;align-items:center;gap:6px;margin-top:4px">
          <input type="checkbox" name="system.ignoreKO" {{#if system.ignoreKO}}checked{{/if}} />
          Ignorer l'incapacité à 0 PV (exception — ce PJ continue d'agir normalement même K.O.)
        </label>
      </div>
      {{/if}}

      {{!-- Classe --}}
      <div class="resource" style="grid-column: 1 / -1;">
        <div class="resource-label">
          <span>Classe</span>
        </div>
        <input type="text" name="system.classe" value="{{system.classe}}" placeholder="Ex: Mage, Épéiste, Druide..."
          {{#if flags.readOnly}}disabled{{/if}} />
      </div>

      {{!-- Monnaie (classique) --}}
      <div class="resource" style="grid-column: 1 / -1;">
        <div class="resource-label">
          <span>Monnaie</span>
          <span class="resource-value">100 cuivre = 1 argent • 100 argent = 1 or</span>
        </div>
        <div class="resource-grid" style="grid-template-columns: 1fr 1fr 1fr; gap: 10px;">
          <div>
            <label>Cuivre</label>
            <input type="number" name="system.monnaie.cuivre" value="{{system.monnaie.cuivre}}" min="0" {{#if
              flags.readOnly}}disabled{{/if}} />
          </div>
          <div>
            <label>Argent</label>
            <input type="number" name="system.monnaie.argent" value="{{system.monnaie.argent}}" min="0" {{#if
              flags.readOnly}}disabled{{/if}} />
          </div>
          <div>
            <label>Or</label>
            <input type="number" name="system.monnaie.or" value="{{system.monnaie.or}}" min="0" {{#if
              flags.readOnly}}disabled{{/if}} />
          </div>
        </div>
      </div>
    </div>
  </header>

  {{!-- =========================
  TABS (Observer = page 1 seulement)
  ========================== --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <span class="header-toggle" title="Masquer/afficher le résumé" style="margin-right:auto;font-size:10px;cursor:pointer;padding:2px 6px;border-radius:6px;opacity:.6;user-select:none">▲</span>
    <a class="item" data-tab="stats">Caractéristiques</a>

    {{#unless flags.limitedView}}
    <a class="item" data-tab="inventory">Inventaire</a>
    <a class="item" data-tab="equipment">Équipement</a>
    <a class="item" data-tab="consumables">Consommables</a>
    <a class="item" data-tab="spells">Sorts</a>
    <a class="item" data-tab="skills">Compétences</a>
    <a class="item" data-tab="quests">Quêtes</a>
    {{/unless}}
  </nav>

  <section class="sheet-body">

    {{!-- =========================
    TAB: STATS (visible pour tous)
    ========================== --}}
    <div class="tab" data-group="primary" data-tab="stats">
      <div class="grid-2">

        <section class="card">
          <h2>Caractéristiques</h2>

          <div class="stats-grid">
            {{!-- FORCE --}}
            <div class="stat-row">
              <label>Force</label>
              <div class="stat-cols">
                {{#if flags.isGM}}
                <div class="stat-col">
                  <small class="muted">Base</small>
                  <input type="number" name="system.principales.force" value="{{system.principales.force}}" {{#unless
                    flags.isGM}}disabled{{/unless}} />
                </div>
                {{/if}}
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="number" value="{{system.derived.effective.principales.force}}" disabled />
                </div>
              </div>
            </div>

            {{!-- INT --}}
            <div class="stat-row">
              <label>Intelligence</label>
              <div class="stat-cols">
                {{#if flags.isGM}}
                <div class="stat-col">
                  <small class="muted">Base</small>
                  <input type="number" name="system.principales.intelligence"
                    value="{{system.principales.intelligence}}" {{#unless flags.isGM}}disabled{{/unless}} />
                </div>
                {{/if}}
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="number" value="{{system.derived.effective.principales.intelligence}}" disabled />
                </div>
              </div>
            </div>

            {{!-- DEX --}}
            <div class="stat-row">
              <label>Dextérité</label>
              <div class="stat-cols">
                {{#if flags.isGM}}
                <div class="stat-col">
                  <small class="muted">Base</small>
                  <input type="number" name="system.principales.dexterite" value="{{system.principales.dexterite}}"
                    {{#unless flags.isGM}}disabled{{/unless}} />
                </div>
                {{/if}}
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="number" value="{{system.derived.effective.principales.dexterite}}" disabled />
                </div>
              </div>
            </div>

            {{!-- ACUITE --}}
            <div class="stat-row">
              <label>Acuité</label>
              <div class="stat-cols">
                {{#if flags.isGM}}
                <div class="stat-col">
                  <small class="muted">Base</small>
                  <input type="number" name="system.principales.acuite" value="{{system.principales.acuite}}" {{#unless
                    flags.isGM}}disabled{{/unless}} />
                </div>
                {{/if}}
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="number" value="{{system.derived.effective.principales.acuite}}" disabled />
                </div>
              </div>
            </div>

            {{!-- ENDURANCE --}}
            <div class="stat-row">
              <label>Endurance</label>
              <div class="stat-cols">
                {{#if flags.isGM}}
                <div class="stat-col">
                  <small class="muted">Base</small>
                  <input type="number" name="system.principales.endurance" value="{{system.principales.endurance}}"
                    {{#unless flags.isGM}}disabled{{/unless}} />
                </div>
                {{/if}}
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="number" value="{{system.derived.effective.principales.endurance}}" disabled />
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="card">
          <h2>Défenses</h2>

          <div class="stats-grid">
            <div class="stat-row">
              <label>Armure fixe (physique)</label>
              <div class="stat-cols">
                {{#if flags.isGM}}
                <div class="stat-col">
                  <small class="muted">Base</small>
                  <input type="number" name="system.defenses.armureFixe" value="{{system.defenses.armureFixe}}"
                    {{#unless flags.isGM}}disabled{{/unless}} />
                </div>
                {{/if}}
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="number" value="{{system.derived.effective.defenses.armureFixe}}" disabled />
                </div>
              </div>
            </div>

            <div class="stat-row">
              <label>Résistance fixe (magique)</label>
              <div class="stat-cols">
                {{#if flags.isGM}}
                <div class="stat-col">
                  <small class="muted">Base</small>
                  <input type="number" name="system.defenses.resistanceFixe" value="{{system.defenses.resistanceFixe}}"
                    {{#unless flags.isGM}}disabled{{/unless}} />
                </div>
                {{/if}}
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="number" value="{{system.derived.effective.defenses.resistanceFixe}}" disabled />
                </div>
              </div>
            </div>

            <div class="stat-row">
              <label>Score Armure (physique)</label>
              <div class="stat-cols">
                {{#if flags.isGM}}
                <div class="stat-col">
                  <small class="muted">Base</small>
                  <input type="number" name="system.defenses.scoreArmure" value="{{system.defenses.scoreArmure}}"
                    {{#unless flags.isGM}}disabled{{/unless}} />
                </div>
                {{/if}}
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="number" value="{{system.derived.effective.defenses.scoreArmure}}" disabled />
                </div>
              </div>
            </div>

            <div class="stat-row">
              <label>Réduction physique (%)</label>
              <div class="stat-cols">
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="text" value="{{system.derived.reductions.physiquePct}}%" disabled />
                </div>
              </div>
            </div>

            <div class="stat-row">
              <label>Score Résistance (magique)</label>
              <div class="stat-cols">
                {{#if flags.isGM}}
                <div class="stat-col">
                  <small class="muted">Base</small>
                  <input type="number" name="system.defenses.scoreResistance"
                    value="{{system.defenses.scoreResistance}}" {{#unless flags.isGM}}disabled{{/unless}} />
                </div>
                {{/if}}
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="number" value="{{system.derived.effective.defenses.scoreResistance}}" disabled />
                </div>
              </div>
            </div>

            <div class="stat-row">
              <label>Réduction magique (%)</label>
              <div class="stat-cols">
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="text" value="{{system.derived.reductions.magiquePct}}%" disabled />
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="card">
          <h2>Combat</h2>
          <div class="stats-grid">
            <div class="stat-row">
              <label>Initiative</label>
              <div class="stat-cols">
                <div class="stat-col">
                  <small class="muted">Total</small>
                  <input type="text" value="{{#if (gte system.derived.initiativeMod 0)}}+{{/if}}{{system.derived.initiativeMod}}" disabled />
                </div>
              </div>
            </div>
            <div class="stat-row">
              <label>Toucher physique</label>
              <div class="stat-cols">
                <div class="stat-col">
                  <small class="muted">Bonus au TN</small>
                  <input type="text" value="{{#if (gte system.derived.toucherPhysique 0)}}+{{/if}}{{system.derived.toucherPhysique}}" disabled />
                </div>
              </div>
            </div>
            <div class="stat-row">
              <label>Toucher magique</label>
              <div class="stat-cols">
                <div class="stat-col">
                  <small class="muted">Bonus au TN</small>
                  <input type="text" value="{{#if (gte system.derived.toucherMagique 0)}}+{{/if}}{{system.derived.toucherMagique}}" disabled />
                </div>
              </div>
            </div>
          </div>
          <small class="muted">Positif = plus facile à toucher (réduit le TN nécessaire), négatif = plus dur. Vient de l'équipement, des sorts/effets, de la couverture ou de l'épuisement.</small>
        </section>

        <section class="panel-states" style="grid-column: 1 / -1;">
          <header class="panel-title">
            <h2>États</h2>

            {{#if flags.isGM}}
            <button type="button" data-action="stateAdd">+ Ajouter</button>
            {{/if}}
          </header>

          <ul class="state-list">
            {{#each system.etatsActifs as |e|}}
            <li class="state-row" data-state-id="{{e.id}}">
              <div class="state-main">
                <b>{{e.label}}</b>

                {{#if e.isAura}}
                <span class="muted" style="margin-left:6px;">[AURA]</span>
                {{/if}}

                {{#if e.isBeneficial}}
                <span class="muted" style="margin-left:6px;">[BUFF]</span>
                {{/if}}

                {{#if e.isHarmful}}
                <span class="muted" style="margin-left:6px;">[AFFLICTION]</span>
                {{/if}}

                <span class="muted">({{e.remaining}} tour{{#unless (eq e.remaining 1)}}s{{/unless}})</span>

                {{#if e.cleanseDC}}
                <span class="muted">Retrait: {{e.cleanseDC}}+</span>
                {{/if}}

                {{#if e.summary}}
                <div class="muted" style="margin-top:4px;">
                  {{e.summary}}
                </div>
                {{else}}
                {{#if e.dot.flat}}
                <div class="muted" style="margin-top:4px;">
                  {{#if (gte e.dot.flat 0)}}Dégâts/tour: {{e.dot.flat}}{{else}}Soin/tour: {{e.dot.flat}}{{/if}}
                </div>
                {{/if}}
                {{#if e.dot.fatiguePerTick}}
                <div class="muted" style="margin-top:4px;">
                  {{#if (gte e.dot.fatiguePerTick 0)}}Épuise: +{{e.dot.fatiguePerTick}} fatigue/tour{{else}}Repose: {{e.dot.fatiguePerTick}} fatigue/tour{{/if}}
                </div>
                {{/if}}
                {{/if}}
              </div>

              <div class="state-actions">
                {{#if ../flags.isGM}}
                <button type="button" data-action="stateEdit" data-id="{{e.id}}">✎</button>
                <button type="button" data-action="stateDelete" data-id="{{e.id}}">🗑</button>
                {{/if}}
                <button type="button" data-action="stateShow" data-id="{{e.id}}">?</button>
              </div>
            </li>
            {{/each}}
          </ul>
        </section>

      </div>
    </div>

    {{!-- =========================
    Les onglets suivants : uniquement si pas limitedView
    ========================== --}}
    {{#unless flags.limitedView}}

    {{!-- TAB: INVENTORY --}}
    <div class="tab" data-group="primary" data-tab="inventory">
      <section class="card">
        <div class="toolbar">
          <h2>Inventaire</h2>

          {{!-- Création : MJ uniquement --}}
          {{#if flags.isGM}}
          <div class="tool-actions">
            <button type="button" class="btn" data-action="createItem" data-type="loot">+ Objet</button>
          </div>
          {{/if}}
        </div>

        <ol class="items-list">
          <li class="items-header">
            <span>Nom</span>
            <span>Qté</span>
            <span>Poids</span>
            <span>Total</span>
            <span></span>
          </li>

          {{#each items.inventaire as |it|}}
          <li class="item" data-item-id="{{it._id}}">
            <span class="name">
              <img src="{{it.img}}" alt="" />
              <a class="item-edit">{{it.name}}</a>
            </span>

            {{#if ../flags.isGM}}
            <span><input type="number" value="{{it.system.qte}}" min="0" data-field="system.qte" /></span>
            <span><input type="number" value="{{it.system.poids}}" min="0" step="0.1"
                data-field="system.poids" /></span>
            {{else}}
            <span>{{it.system.qte}}</span>
            <span>{{it.system.poids}}</span>
            {{/if}}

            <span class="total">{{it._derived.poidsTotal}}</span>

            <span class="actions">
              {{#if ../flags.isGM}}
              <button type="button" class="icon" data-action="deleteItem" title="Supprimer">✕</button>
              {{/if}}
            </span>
          </li>
          {{/each}}
        </ol>
      </section>
    </div>

    {{!-- TAB: EQUIPMENT --}}
    <div class="tab" data-group="primary" data-tab="equipment">
      <section class="card">
        <div class="toolbar">
          <h2>Équipement</h2>

          {{#if flags.isGM}}
          <div class="tool-actions">
            <button type="button" class="btn" data-action="createItem" data-type="weapon">+ Arme</button>
            <button type="button" class="btn" data-action="createItem" data-type="armor">+ Armure</button>
          </div>
          {{/if}}
        </div>

        <p class="hint">
          Slots : tête • torse • taille • bras • mains • jambes • pieds • main gauche • main droite • artefact
          <br />Arme 2 mains : occupe main droite + main gauche.
        </p>

        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
          {{!-- COL 1: SLOTS --}}
          <div>
            <h3>Slots</h3>

            <div style="display:flex; flex-direction:column; gap:10px;">
              {{#each equipSlots as |s|}}
              <div data-slot="{{s.key}}"
                style="border:1px solid rgba(255,255,255,0.12); border-radius:10px; padding:10px;">
                <div style="display:flex; justify-content:space-between; align-items:center; gap:10px;">
                  <b>{{s.label}}</b>
                  {{#if s.locked}}<small style="opacity:0.8;">(lié)</small>{{/if}}
                </div>

                <div style="margin-top:8px; display:flex; gap:10px; align-items:center;">
                  <select style="flex:1;" data-action="equipSlotSelect" data-slot="{{s.key}}" {{#if
                    s.locked}}disabled{{/if}}>
                    <option value="">Aucun</option>
                    {{#each s.options as |opt|}}
                    <option value="{{opt._id}}" {{#if opt.selected}}selected{{/if}}>
                      {{opt.name}}{{#if opt.system.twoHands}} (2 mains){{/if}}
                    </option>
                    {{/each}}
                  </select>

                  {{#if s.item}}
                  <img src="{{s.item.img}}" alt=""
                    style="width:32px; height:32px; border-radius:6px; object-fit:cover;" />
                  {{/if}}
                </div>

                {{#if s.item}}
                <div class="item" data-item-id="{{s.item._id}}"
                  style="margin-top:8px; display:flex; justify-content:space-between; gap:10px; align-items:center;">
                  <div style="flex:1;">
                    <a class="item-edit"><b>{{s.item.name}}</b></a>
                    <div style="opacity:0.8; font-size:12px;">
                      Slot: {{s.item.system.emplacement}}
                      {{#if s.item.system.twoHands}} — 2 mains{{/if}}
                      {{#if s.item.system.damage.dice}} — Dégâts: {{s.item.system.damage.dice}}{{/if}}
                    </div>

                    <div style="opacity:0.8; font-size:12px; margin-top:4px;">
                      Qté: {{s.item.system.qte}} • Poids: {{s.item.system.poids}} • Total:
                      {{s.item._derived.poidsTotal}}
                    </div>
                  </div>

                  {{#if ../flags.isGM}}
                  <button type="button" class="icon" data-action="deleteItem" title="Supprimer">✕</button>
                  {{/if}}
                </div>
                {{else}}
                <div style="margin-top:8px; opacity:0.8;">Vide</div>
                {{/if}}
              </div>
              {{/each}}
            </div>
          </div>

          {{!-- COL 2: LISTE RAPIDE --}}
          <div>
            <h3>Équipements possédés</h3>
            <p class="hint" style="margin-bottom:8px;">
              Modifie poids/quantité dans l’onglet Inventaire si besoin.
            </p>

            <ol class="items-list simple">
              {{#each items.equipe as |it|}}
              <li class="item" data-item-id="{{it._id}}" style="display:flex; align-items:center; gap:10px;">
                <img src="{{it.img}}" alt="" style="width:28px; height:28px; border-radius:6px; object-fit:cover;" />
                <div style="flex:1;">
                  <a class="item-edit"><b>{{it.name}}</b></a>
                  <div style="opacity:0.8; font-size:12px;">Équipé sur: {{it.system.emplacement}}</div>
                </div>
              </li>
              {{/each}}

              {{#each items.nonEquipe as |it|}}
              <li class="item" data-item-id="{{it._id}}" style="display:flex; align-items:center; gap:10px;">
                <img src="{{it.img}}" alt="" style="width:28px; height:28px; border-radius:6px; object-fit:cover;" />
                <div style="flex:1;">
                  <a class="item-edit"><b>{{it.name}}</b></a>
                  <div style="opacity:0.8; font-size:12px;">Slot: {{it.system.emplacement}}</div>
                </div>
                {{#if ../flags.isGM}}
                <button type="button" class="icon" data-action="deleteItem" title="Supprimer">✕</button>
                {{/if}}
              </li>
              {{/each}}
            </ol>
          </div>
        </div>
      </section>
    </div>

    {{!-- TAB: CONSUMABLES --}}
    <div class="tab" data-group="primary" data-tab="consumables">
      <section class="card">
        <div class="toolbar">
          <h2>Consommables</h2>

          {{#if flags.isGM}}
          <div class="tool-actions">
            <button type="button" class="btn" data-action="createItem" data-type="consumable">+ Consommable</button>
          </div>
          {{/if}}
        </div>

        <ol class="items-list simple">
          {{#each items.consommables as |it|}}
          <li class="item" data-item-id="{{it._id}}">
            <span class="name">
              <img src="{{it.img}}" alt="" />
              <a class="item-edit">{{it.name}}</a>
              <small>Utilisations: {{it.system.utilisations}}</small>
              {{#if it.system.effet}}<div class="muted" style="font-size:11px;margin-top:2px">{{it.system.effet}}</div>{{/if}}
            </span>

            <span class="actions">
              {{#if ../flags.isGM}}
              <button type="button" class="icon" data-action="deleteItem" title="Supprimer">✕</button>
              {{/if}}
            </span>
          </li>
          {{/each}}
        </ol>
      </section>
    </div>

    {{!-- TAB: SPELLS --}}
    <div class="tab" data-group="primary" data-tab="spells">
      <section class="card">
        <div class="toolbar">
          <h2>Sorts</h2>

          {{#if flags.isGM}}
          <div class="tool-actions">
            <button type="button" class="btn" data-action="createItem" data-type="spell">+ Sort</button>
          </div>
          {{/if}}
        </div>

        <ol class="items-list simple">
  {{#each items.sorts as |it|}}
  <li class="item" data-item-id="{{it._id}}">
    <span class="name">
      <img src="{{it.img}}" alt="" />
      <a class="item-edit"><b>{{it.name}}</b></a>

      <div class="spell-meta" style="opacity:.85; font-size:12px; margin-top:4px; display:flex; flex-wrap:wrap; gap:10px;">
        <span>⚡ {{#if (eq it._ui.speed "rapide")}}Rapide{{else}}Normal{{/if}}</span>
        <span>💧 Mana: {{it._ui.coutMana}}</span>
        <span>📏 Sort: {{it._ui.rangeMin}}–{{it._ui.rangeMax}}</span>

        {{#if it._ui.auraEnabled}}
          <span>🌀 Aura: {{it._ui.auraMin}}–{{it._ui.auraMax}} ({{it._ui.auraTarget}})</span>
        {{/if}}

        <span>🎯 Diff: +{{it._ui.difficulte}}</span>

        <span>
          ⏳ CD:
          <b style="{{#if it._ui.onCooldown}}color:#b00;{{else}}color:#0a0;{{/if}}">
            {{it._ui.cdRestant}}/{{it._ui.cdMax}}
          </b>
        </span>

        {{#if it._ui.modsSummary}}
          <span>✨ {{it._ui.modsSummary}}</span>
        {{/if}}
      </div>

      {{#if it._previewEffects.length}}
      <div style="margin-top:8px; padding:8px; border:1px solid rgba(255,255,255,.12); border-radius:10px;">
        <div style="font-size:12px; opacity:.85; margin-bottom:6px;"><b>Effets (preview)</b></div>
        <ul style="margin:0; padding-left:16px; font-size:12px; opacity:.85;">
          {{#each it._previewEffects as |fx|}}
          <li>
            <b>{{fx.label}}</b>
            <span style="opacity:.8;">[{{fx.when}} • {{fx.target}}]</span>
            {{#if fx.duration}} <span style="opacity:.8;">({{fx.duration}} tours)</span>{{/if}}
          </li>
          {{/each}}
        </ul>
      </div>
      {{/if}}
    </span>

    <span class="actions">
  {{#if ../flags.isOwner}}
  <button type="button" class="btn small" data-action="declareSpell" data-item-id="{{it._id}}">
  Déclarer
</button>
  {{/if}}

  {{#if ../flags.isGM}}
  <button type="button" class="icon" data-action="deleteItem" title="Supprimer">✕</button>
  {{/if}}
</span>
  </li>
  {{/each}}
</ol>
      </section>
    </div>

    {{!-- TAB: SKILLS (system.skills) --}}
    <div class="tab" data-group="primary" data-tab="skills">
      <section class="card">
        <div class="toolbar">
          <h2>Compétences</h2>

          <div class="hint" style="margin-left:auto;">
            Total: <b>{{calc.skillsTotal}}</b> / <b>{{calc.skillsCap}}</b> niveaux
          </div>
        </div>

        <ol class="items-list simple">
          {{#each skills as |s|}}
          <li class="item" data-skill="{{s.key}}">
            <span class="name" style="display:flex; flex-direction:column; gap:4px;">
              <div style="display:flex; align-items:center; gap:10px;">
                <b>{{s.label}}</b>
                <small style="opacity:.85;">Niv: {{s.level}}</small>
                <small style="opacity:.85;">XP: {{s.xp}} / {{s.next}} ({{s.pct}}%)</small>
              </div>

              {{#if s.grants}}
              <small style="opacity:.8;">
                Bonus par niveau :
                {{#each s.grants}}
                <b>{{@key}}</b> +{{this}}
                {{/each}}
              </small>
              {{/if}}
            </span>

            <span class="actions" style="display:flex; gap:8px; align-items:center;">
              {{#if ../flags.isGM}}
              <input class="skill-xp-add" type="number" value="0" style="width:90px;" />
              <button type="button" class="btn small" data-action="skillAddXp">+ XP</button>
              <button type="button" class="btn small" data-action="skillRemoveXp">- XP</button>
              {{/if}}
            </span>
          </li>
          {{/each}}
        </ol>

      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="quests">
      <section class="card">
        <div class="toolbar">
          <h2>Quêtes</h2>
        </div>

        <ol class="items-list simple">
          {{#each quests as |q|}}
          <li class="item" data-item-id="{{q.id}}" style="flex-direction:column;align-items:stretch;gap:6px">
            <div style="display:flex; align-items:center; gap:8px;">
              <b class="item-edit" style="cursor:pointer">{{q.name}}</b>
              <small style="opacity:.85;
                {{#if (eq q.statut "reussie")}}color:#1d9e75;{{/if}}
                {{#if (eq q.statut "echouee")}}color:#c0392b;{{/if}}">
                {{q.statutLabel}}
              </small>
              {{#if (and ../flags.isGM q.totalEtapes)}}
              <small style="opacity:.7;margin-left:auto">Étape {{q.etapeActuelleNum}} / {{q.totalEtapes}}</small>
              {{/if}}
            </div>

            {{#each q.allEtapes as |etape|}}
              {{#if (or ../../flags.isGM (not etape.hidden))}}
              <div style="font-size:12px;padding:4px 6px;border-radius:6px;
                          {{#if etape.isCurrent}}background:rgba(29,158,117,0.1);{{/if}}
                          {{#if etape.hidden}}opacity:.5;border:1px dashed var(--color-border-tertiary);{{/if}}">
                <div style="display:flex;align-items:center;gap:6px">
                  <b>Étape {{etape.num}}{{#if etape.label}} — {{etape.label}}{{/if}}</b>
                  {{#if etape.isCurrent}}<span style="color:#1d9e75;font-size:10px">EN COURS</span>{{/if}}
                  {{#if etape.isPast}}<span style="color:var(--color-text-secondary);font-size:10px">terminée</span>{{/if}}
                  {{#if etape.hidden}}<span style="color:var(--color-text-secondary);font-size:10px">(caché du joueur)</span>{{/if}}
                </div>
                {{#if etape.isCurrent}}
                  {{#each etape.objectifs}}
                    <div style="padding-left:14px">{{#if this.fait}}✅{{else}}⬜{{/if}} {{this.text}}</div>
                  {{/each}}
                {{/if}}
                {{#if (and ../../flags.isGM etape.isPast)}}
                  {{#each etape.objectifs}}
                    <div style="padding-left:14px;opacity:.7">{{#if this.fait}}✅{{else}}⬜{{/if}} {{this.text}}</div>
                  {{/each}}
                {{/if}}
              </div>
              {{/if}}
            {{/each}}

            <span class="actions" style="display:flex; gap:6px; align-items:center;">
              <button type="button" class="btn small item-edit" title="Ouvrir / éditer">🔎</button>
              {{#if ../flags.isGM}}
              {{#if q.isActive}}
                {{#if q.hasMoreEtapes}}
                <button type="button" class="btn small" data-action="questNextEtape" data-item-id="{{q.id}}">Étape suivante ▶</button>
                {{/if}}
                <button type="button" class="btn small" data-action="questComplete" data-item-id="{{q.id}}">Réussite</button>
                <button type="button" class="btn small" data-action="questFail" data-item-id="{{q.id}}">Échec</button>
              {{/if}}
              {{/if}}
            </span>
          </li>
          {{/each}}
        </ol>
      </section>
    </div>

    {{/unless}}

  </section>
</div>